    },
    {
      "source": "/ai-file-renamer/",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/:path((?!e/).+)/",
      "destination": "/:path*",
      "permanent": true
    },
    {
      "source": "/file-renamer",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/ai-file-renamer",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/rename-files-with-ai",
