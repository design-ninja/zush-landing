    },
    {
      "source": "/blog/photo-management-workflow-photographers-mac",
      "destination": "/blog/best-ways-to-organize-photos-on-mac",
      "permanent": true
    },
    {
      "source": "/blog/how-ai-image-recognition-works",
      "destination": "/methodology",
