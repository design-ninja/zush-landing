      "permanent": true
    },
    {
      "source": "/:locale(de|fr|es|pt-br|nl|it|ja|ko|zh-cn|hi|ar)/batch-rename-files",
      "destination": "/:locale",
      "permanent": true
    },
    {
      "source": "/ai-image-renamer",
