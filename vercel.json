{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "permanent": true
    },
    {
      "source": "/ai-photo-renamer",
      "destination": "/rename-photos-with-ai",
      "permanent": true
    },
    {
      "source": "/ai-screenshot-renamer",
      "destination": "/rename-screenshots-with-ai",
      "permanent": true
    },
    {
      "source": "/ai-document-renamer",
      "destination": "/rename-documents-with-ai",
      "permanent": true
    },
    {
      "source": "/ai-pdf-renamer",
      "destination": "/rename-pdf-with-ai",
      "permanent": true
    },
    {
      "source": "/blog/organize-photos-by-date-mac",
      "destination": "/blog/best-ways-to-organize-photos-on-mac",
      "permanent": true
    },
    {
      "source": "/blog/how-to-find-photos-on-mac",
      "destination": "/blog/best-ways-to-organize-photos-on-mac",
      "permanent": true
    },
    {
      "source": "/blog/photo-backup-strategy-mac",
      "destination": "/blog/best-ways-to-organize-photos-on-mac",
      "permanent": true
    },
    {
      "source": "/blog/smart-folders-mac-guide",
      "destination": "/blog/finder-tags-guide-organize-files-mac",
      "permanent": true
    },
    {
      "source": "/blog/spotlight-search-tips-find-files-faster-mac",
      "destination": "/blog/finder-tags-guide-organize-files-mac",
      "permanent": true
    },
    {
      "source": "/blog/organize-design-assets-ui-ux-workflow",
      "destination": "/blog/digital-asset-management-designers-mac",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
