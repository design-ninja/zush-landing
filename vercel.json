{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "e.zushapp.com"
        }
      ],
      "destination": "https://zushapp.com",
      "permanent": true
    },
    {
      "source": "/e/",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/e",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/ai-image-renamer/",
