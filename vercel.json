{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "permanent": true
    },
    {
      "source": "/rename-files-with-ai",
      "destination": "/ai-file-renamer",
      "permanent": true
    },
    {
      "source": "/rename-images-with-ai",
      "destination": "/ai-image-renamer",
      "permanent": true
    },
    {
      "source": "/ai-document-renamer",
      "destination": "/rename-documents-with-ai",
      "permanent": true
    },
    {
      "source": "/ai-pdf-renamer",
      "destination": "/rename-pdf-with-ai",
      "permanent": true
    },
    {
      "source": "/ai-screenshot-renamer",
      "destination": "/rename-screenshots-with-ai",
      "permanent": true
    },
    {
      "source": "/ai-photo-renamer",
      "destination": "/rename-photos-with-ai",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
