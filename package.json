{
  "name": "zush-landing",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "author": "lirik",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "dev:sandbox": "astro dev --mode sandbox",
    "build": "pnpm check:paddle-env && astro build",
    "build:sandbox": "pnpm check:paddle-env:sandbox && astro build --mode sandbox",
    "preview": "astro preview",
    "lint": "eslint .",
    "check:astro": "astro check",
    "check:locale": "node scripts/check-locale-autodetect.mjs",
    "check:paddle-env": "node scripts/check-production-paddle-env.mjs",
    "check:paddle-env:sandbox": "MODE=sandbox ALLOW_SANDBOX_PADDLE_BUILD=1 node scripts/check-production-paddle-env.mjs",
    "check:payments": "node scripts/verify-payments.mjs",
    "check:seo-middleware": "node scripts/check-seo-middleware.mjs",
    "check:seo-redirects": "node scripts/check-seo-redirects.mjs",
    "check:html": "node scripts/check-html-smoke.mjs",
    "check:links": "node scripts/check-internal-links.mjs",
    "seo:indexnow": "node scripts/indexnow-ping.mjs",
    "check:seo": "pnpm check:astro && pnpm check:locale && pnpm check:payments && pnpm check:seo-middleware && pnpm check:seo-redirects && pnpm build && pnpm check:html && pnpm check:links",
    "check:seo:sandbox": "pnpm check:astro && pnpm check:locale && pnpm check:payments && pnpm check:seo-middleware && pnpm check:seo-redirects && pnpm build:sandbox && pnpm check:html && pnpm check:links",
    "youtube:auth": "node scripts/youtube-upload.mjs auth",
    "youtube:dry-run": "node scripts/youtube-upload.mjs dry-run",
    "youtube:upload": "node scripts/youtube-upload.mjs upload",
    "youtube:dry-run:hq": "node scripts/youtube-upload.mjs dry-run --config scripts/youtube-videos-hq-light.json",
    "youtube:upload:hq": "node scripts/youtube-upload.mjs upload --config scripts/youtube-videos-hq-light.json",
    "promo:feature-screenshots": "node scripts/promo/zush-feature-screenshots.mjs",
    "promo:feature-videos": "node scripts/promo/zush-feature-videos.mjs",
    "promo:windows-feature-screenshots": "node scripts/promo/zush-windows-feature-screenshots.mjs"
  },
  "dependencies": {
    "@remotion/player": "^4.0.461",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remotion": "^4.0.461"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/react": "^6.0.0",
    "@astrojs/sitemap": "3.7.3",
    "@astrojs/starlight": "^0.41.1",
    "@astrojs/vercel": "^11.0.0",
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/outfit": "^5.2.8",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/functions": "3.4.4",
    "astro": "^7.0.3",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "remark-gfm": "^4.0.1",
    "sass": "^1.99.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3"
  }
}
