PUBLIC_SUPABASE_URL=

PUBLIC_PADDLE_TOKEN=your_paddle_token_here
PUBLIC_PADDLE_ENVIRONMENT=sandbox
PUBLIC_PADDLE_PRO_MONTHLY_PRICE_ID=pri_...
PUBLIC_PADDLE_PRO_ONE_TIME_PRICE_ID=pri_...
PADDLE_API_KEY=

OPENAI_API_KEY=

GH_TOKEN=
GITHUB_TOKEN=

# Google Search Console
GSC_SITE_URL=
GSC_TOKEN_FILE=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional Google Ads website conversion tracking.
# Use values from Google Ads > Goals > Conversions > Website.
PUBLIC_GOOGLE_ADS_ID=AW-000000000
PUBLIC_GOOGLE_ADS_DOWNLOAD_CONVERSION_LABEL=
PUBLIC_GOOGLE_ADS_PURCHASE_CONVERSION_LABEL=

# Google Ads MCP / API access (local only).
# Requires Google Ads API enabled in the Google Cloud project.
# Keep GOOGLE_ADS_MCP_OAUTH_CLIENT_ID / GOOGLE_ADS_MCP_OAUTH_CLIENT_SECRET
# unset for local stdio mode; setting them switches the MCP server to HTTP.
GOOGLE_PROJECT_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Optional server-side download conversion upload.
# These are used by /download/mac and must be set in Vercel production
# for first-party Google Ads download conversion attribution.
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=4714692966
GOOGLE_ADS_DOWNLOAD_UPLOAD_CONVERSION_ACTION_ID=

# YouTube uploader (local script only)
YOUTUBE_REDIRECT_PORT=8787

# PostHog
# Project key also gates the server-side capture in /download/mac and the
# distinct_id read from PostHog's own cookie.
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=/e
POSTHOG_PERSONAL_API_KEY=