---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FeatureLandingPageShell from '@/components/FeatureLandingPage/FeatureLandingPageShell.astro';
import { getFeaturePageProps } from '@/utils/featurePageProps';
import RenameDocumentsWithAI from '@/views/FeaturePages/RenameDocumentsWithAI';
import { getSeoForPath } from '@/seo/config';
import { buildFeatureBreadcrumbJsonLd } from '@/utils/jsonLd';

const seo = getSeoForPath('/rename-documents-with-ai');
const featurePage = getFeaturePageProps(RenameDocumentsWithAI);
---

<BaseLayout seo={seo} jsonLd={[featurePage.jsonLd, buildFeatureBreadcrumbJsonLd(featurePage.h1, '/rename-documents-with-ai')]}>
  <FeatureLandingPageShell {...featurePage} />
</BaseLayout>
