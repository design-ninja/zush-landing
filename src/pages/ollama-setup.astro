---
import BaseLayout from '@/layouts/BaseLayout.astro';
import OllamaSetupView from '@/views/OllamaSetup';
import { getSeoForPath } from '@/seo/config';
import { buildPageBreadcrumbJsonLd, buildWebPageJsonLd } from '@/utils/jsonLd';

const seo = getSeoForPath('/ollama-setup');
const jsonLd = [
  buildWebPageJsonLd({
    pagePath: '/ollama-setup',
    title: seo.title,
    description: seo.description,
    type: 'TechArticle',
  }),
  buildPageBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Ollama Setup', path: '/ollama-setup' },
  ]),
];
---

<BaseLayout seo={seo} jsonLd={jsonLd}>
  <OllamaSetupView />
  <section class="setup-related-docs" aria-labelledby="ollama-related-docs-title">
    <div class="setup-related-docs__inner">
      <h2 id="ollama-related-docs-title">Related Zush docs</h2>
      <div class="setup-related-docs__links">
        <a href="/docs/offline-ai/">Offline AI docs</a>
        <a href="/docs/ai-modes/">AI modes</a>
        <a href="/docs/supported-file-types/">Supported file types</a>
        <a href="/docs/privacy-security/">Privacy and security</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .setup-related-docs {
    padding: 0 0 4rem;
  }

  .setup-related-docs__inner {
    width: min(100% - 2rem, 54rem);
    margin: 0 auto;
  }

  .setup-related-docs h2 {
    margin: 0 0 1rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--foreground);
  }

  .setup-related-docs__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .setup-related-docs__links a {
    color: var(--foreground);
    background: var(--muted);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 0.7rem 0.9rem;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
  }

  .setup-related-docs__links a:hover {
    border-color: var(--primary);
    color: var(--primary);
  }
</style>
