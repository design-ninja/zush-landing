---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FeatureLandingPageShell from '@/components/FeatureLandingPage/FeatureLandingPageShell.astro';
import { getFeaturePageProps, VIDEO_SCHEMA } from '@/utils/featurePageProps';
import AIDocumentRenamer from '@/views/FeaturePages/AIDocumentRenamer';
import { getSeoForPath } from '@/seo/config';
import { buildFeatureBreadcrumbJsonLd } from '@/utils/jsonLd';

const seo = getSeoForPath('/ai-document-renamer');
const featurePage = getFeaturePageProps(AIDocumentRenamer);
---

<BaseLayout seo={seo} jsonLd={[featurePage.jsonLd, VIDEO_SCHEMA, buildFeatureBreadcrumbJsonLd(featurePage.h1, '/ai-document-renamer')]}>
  <FeatureLandingPageShell {...featurePage} />
</BaseLayout>
