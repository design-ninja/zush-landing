---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FeatureLandingPageShell from '@/components/FeatureLandingPage/FeatureLandingPageShell.astro';
import { getFeaturePageProps, VIDEO_SCHEMA } from '@/utils/featurePageProps';
import RenameScreenshotsWithAI from '@/views/FeaturePages/RenameScreenshotsWithAI';
import { getSeoForPath } from '@/seo/config';
import { buildFeatureBreadcrumbJsonLd } from '@/utils/jsonLd';

const seo = getSeoForPath('/rename-screenshots-with-ai');
const featurePage = getFeaturePageProps(RenameScreenshotsWithAI);
---

<BaseLayout seo={seo} jsonLd={[featurePage.jsonLd, VIDEO_SCHEMA, buildFeatureBreadcrumbJsonLd(featurePage.h1, '/rename-screenshots-with-ai')]}>
  <FeatureLandingPageShell {...featurePage} />
</BaseLayout>
