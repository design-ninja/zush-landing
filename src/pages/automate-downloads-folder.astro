---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FeatureLandingPageShell from '@/components/FeatureLandingPage/FeatureLandingPageShell.astro';
import { SEARCH_LANDING_PAGES } from '@/data/searchLandingPages';
import { getSeoForPath } from '@/seo/config';
import { buildFeatureBreadcrumbJsonLd } from '@/utils/jsonLd';

const seo = getSeoForPath('/automate-downloads-folder');
const page = SEARCH_LANDING_PAGES['automate-downloads-folder'];
---

<BaseLayout seo={seo} jsonLd={[page.jsonLd, buildFeatureBreadcrumbJsonLd(page.h1, '/automate-downloads-folder')]}>
  <FeatureLandingPageShell {...page} />
</BaseLayout>
