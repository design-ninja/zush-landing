---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs';
import BlogPost from '@/views/Blog/BlogPost';
import { getAllPosts, getPostBySlug } from '@/data/blog';
import { getBlogSeo, SITE_ORIGIN } from '@/seo/config';
import {
  buildBlogPostingJsonLd,
  buildBreadcrumbJsonLd,
  buildFAQPageJsonLd,
  buildHowToJsonLd,
} from '@/utils/jsonLd';
import { HOW_TO_SCHEMAS } from '@/data/howToSchemas';

export function getStaticPaths() {
  return getAllPosts().map((post) => ({
    params: { slug: post.slug },
    props: { slug: post.slug },
  }));
}

const { slug } = Astro.props;
const parsedPost = getPostBySlug(slug);

if (!parsedPost) {
  throw new Error(`Unknown blog slug: ${slug}`);
}

const { frontmatter, faq } = parsedPost;
const seo = getBlogSeo(frontmatter);
const howTo = HOW_TO_SCHEMAS[frontmatter.slug];
const jsonLd = [
  buildBlogPostingJsonLd(frontmatter),
  buildBreadcrumbJsonLd(frontmatter.title, frontmatter.slug),
  ...(faq.length > 0 ? [buildFAQPageJsonLd(faq)] : []),
  ...(howTo
    ? [buildHowToJsonLd(howTo, `${SITE_ORIGIN}/blog/${frontmatter.slug}`)]
    : []),
];

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog' },
  { label: frontmatter.title },
];
---

<BaseLayout seo={seo} jsonLd={jsonLd}>
  <Breadcrumbs items={breadcrumbItems} />
  <BlogPost slug={slug} />
</BaseLayout>
