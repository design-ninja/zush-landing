---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BackLink from '@/components/BackLink/BackLink.astro';
import BlogBreadcrumbs from '@/components/blog/BlogBreadcrumbs.astro';
import { getAllTags } from '@/data/blog';
import type { SeoMeta } from '@/seo/config';
import headingStyles from '@/components/Heading/Heading.module.scss';
import textStyles from '@/components/Text/Text.module.scss';
import styles from '@/views/Blog/BlogList.module.scss';

const tags = await getAllTags();
const seo: SeoMeta = {
  title: 'Blog Tags — Zush',
  description:
    'Browse focused topic pages on the Zush blog for screenshots, PDFs, automation, naming, and file organization workflows.',
  canonicalPath: '/blog/tags',
  robots: 'noindex, follow',
  ogType: 'website',
};
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog' },
  { label: 'Tags' },
];
---

<BaseLayout seo={seo}>
  <BlogBreadcrumbs items={breadcrumbItems} />
  <div class={styles.BlogList__BreadcrumbBack}>
    <BackLink href='/blog' label='Back to Blog' />
  </div>

  <section class={[styles.BlogList, styles.BlogList_afterBreadcrumbBack].join(' ')}>
    <div class={styles.BlogList__Container}>
      <div class={styles.BlogList__SectionHeader}>
        <h1 class={[headingStyles.Heading, headingStyles.Heading_h1].join(' ')}>
          Blog Tags
        </h1>
        <p
          class={[
            textStyles.Text,
            textStyles.Text_lg,
            textStyles.Text_subtle,
            styles.BlogList__SectionDescription,
          ].join(' ')}
        >
          Browse the cleaned-up topic clusters we use across the blog
        </p>
      </div>

      <div class={styles.BlogList__SectionActions}>
        <a class={styles.BlogList__SectionAction} href='/blog/archive'>
          Browse archive
        </a>
      </div>

      {tags.length > 0 ? (
        <div class={styles.BlogList__TagCloud}>
          {tags.map((tag) => (
            <a class={styles.BlogList__TagCard} href={`/blog/tags/${tag.slug}`}>
              <h2
                class={[
                  headingStyles.Heading,
                  headingStyles.Heading_h4,
                  styles.BlogList__TagTitle,
                ].join(' ')}
              >
                {tag.label}
              </h2>
              <span class={styles.BlogList__TagMeta}>{`${tag.count} article${
                tag.count === 1 ? '' : 's'
              }`}</span>
            </a>
          ))}
        </div>
      ) : (
        <p class={[textStyles.Text, textStyles.Text_md, styles.BlogList__Empty].join(' ')}>
          No tags found
        </p>
      )}
    </div>
  </section>
</BaseLayout>
