---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MethodologyPage from '@/components/MethodologyPage/MethodologyPage.astro';
import { getSeoForPath, toIsoDateTime } from '@/seo/config';

const seo = getSeoForPath('/methodology');
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'Zush Methodology & Benchmarks',
  url: 'https://zushapp.com/methodology',
  inLanguage: 'en',
  datePublished: toIsoDateTime('2026-01-15'),
  dateModified: toIsoDateTime('2026-03-01'),
  lastReviewed: toIsoDateTime('2026-03-01'),
  publisher: {
    '@type': 'Organization',
    name: 'Zush',
    url: 'https://zushapp.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://zushapp.com/logo.png',
    },
  },
  author: {
    '@type': 'Organization',
    name: 'Zush',
    url: 'https://zushapp.com',
  },
  description:
    'Public methodology for AI file renaming recommendations, including scoring criteria, benchmark protocol, and review cadence.',
};
---

<BaseLayout seo={seo} jsonLd={jsonLd}>
  <MethodologyPage />
</BaseLayout>
