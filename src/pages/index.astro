---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HomePageContent from '@/components/HomePage/HomePageContent.astro';
import { HOME_FAQ_DATA } from '@/data/homeFaq';
import { getSeoForPath, HOME_JSON_LD, SITE_ORIGIN } from '@/seo/config';
import { buildFAQPageJsonLd } from '@/utils/jsonLd';
import { getCopy } from '@/i18n/copy';

const seo = getSeoForPath('/');
const copy = getCopy('en');
const homeVideoJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: 'Zush AI batch rename demo',
  description:
    'Zush demo showing AI batch rename review before applying content-aware filenames.',
  thumbnailUrl: `${SITE_ORIGIN}/videos/posters/batch-rename.webp`,
  contentUrl: `${SITE_ORIGIN}/videos/zush-batch-rename.mp4`,
  uploadDate: '2026-01-22T15:03:02+07:00',
  inLanguage: 'en',
  publisher: {
    '@id': `${SITE_ORIGIN}/#organization`,
  },
};
const jsonLd = [
  HOME_JSON_LD,
  homeVideoJsonLd,
  buildFAQPageJsonLd(HOME_FAQ_DATA),
];
---

<BaseLayout seo={seo} jsonLd={jsonLd}>
  <HomePageContent copy={copy} locale="en" />
</BaseLayout>
