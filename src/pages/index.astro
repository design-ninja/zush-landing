---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero';
import Videos from '@/components/Videos';
import SpeedComparison from '@/components/SpeedComparison';
import Features from '@/components/Features/Features.astro';
import SupportedFormats from '@/components/SupportedFormats';
import UseCases from '@/components/UseCases';
import Pricing from '@/components/Pricing/Pricing.astro';
import WhyZush from '@/components/WhyZush';
import FAQ from '@/components/FAQ';
import DownloadCTA from '@/components/DownloadCTA/DownloadCTA.astro';
import CrossPlatformBanner from '@/components/CrossPlatformBanner/CrossPlatformBanner.astro';
import { getSeoForPath, HOME_JSON_LD } from '@/seo/config';
import { getCopy } from '@/i18n/copy';

const seo = getSeoForPath('/');
const copy = getCopy('en');
---

<BaseLayout seo={seo} jsonLd={HOME_JSON_LD}>
  <Hero
    client:load
    title={copy.home.heroTitle}
    titleAccent={copy.home.heroAccent}
    subtitle={copy.home.heroSubtitle}
    buyLabel={copy.home.buyPro}
    downloadLabel={copy.header.download}
    downloadMenu={copy.downloadMenu}
    trustSignals={copy.home.trustSignals}
    slides={copy.home.showcaseSlides}
    renameDemo={copy.home.renameDemo}
    locale="en"
    showInteractiveDemo
  />
  <Videos client:visible autoplayWhenInView copy={copy.home.videos} />
  <Features title={copy.home.featuresTitle} description={copy.home.featuresDescription} copy={copy.home.featureCards} />
  <SupportedFormats
    title={copy.home.supportedFormats}
    imagesLabel={copy.home.images}
    documentsLabel={copy.home.documents}
  />
  <DownloadCTA
    title={copy.home.downloadTitle}
    subtitle={copy.home.downloadSubtitle}
    hintPrefix={copy.home.downloadHintPrefix}
    downloadLabel={copy.header.download}
    downloadMenu={copy.downloadMenu}
  />
  <SpeedComparison client:visible copy={copy.home.speedComparison} />
  <WhyZush copy={copy.home.whyZush} />
  <CrossPlatformBanner />
  <UseCases copy={copy.home.useCases} />
  <Pricing copy={copy.pricing} />
  <FAQ
    client:visible
    title={copy.home.faqTitle}
    description={copy.home.faqDescription}
    items={copy.home.faqItems}
  />
</BaseLayout>
