---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FeatureLandingPageShell from '@/components/FeatureLandingPage/FeatureLandingPageShell.astro';
import { getFeaturePageProps, VIDEO_SCHEMA } from '@/utils/featurePageProps';
import AIPhotoRenamer from '@/views/FeaturePages/AIPhotoRenamer';
import { getSeoForPath } from '@/seo/config';
import { buildFeatureBreadcrumbJsonLd } from '@/utils/jsonLd';

const seo = getSeoForPath('/ai-photo-renamer');
const featurePage = getFeaturePageProps(AIPhotoRenamer);
---

<BaseLayout seo={seo} jsonLd={[featurePage.jsonLd, VIDEO_SCHEMA, buildFeatureBreadcrumbJsonLd(featurePage.h1, '/ai-photo-renamer')]}>
  <FeatureLandingPageShell {...featurePage} />
</BaseLayout>
