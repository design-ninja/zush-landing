---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero';
import Videos from '@/components/Videos';
import Features from '@/components/Features/Features.astro';
import SupportedFormats from '@/components/SupportedFormats';
import UseCases from '@/components/UseCases';
import Pricing from '@/components/Pricing';
import WhyZush from '@/components/WhyZush';
import DownloadCTA from '@/components/DownloadCTA';
import FAQ from '@/components/FAQ';
import PlatformGuides from '@/components/PlatformGuides/PlatformGuides.astro';
import { PLATFORM_LANDING_CONTENT } from '@/data/platformLanding';
import { getSeoForPath, SITE_ORIGIN } from '@/seo/config';
import { buildFAQPageJsonLd, buildFeatureBreadcrumbJsonLd } from '@/utils/jsonLd';

const page = PLATFORM_LANDING_CONTENT.windows;
const seo = getSeoForPath(page.path);

const softwareJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  '@id': `${SITE_ORIGIN}${page.path}#software`,
  name: page.softwareName,
  url: `${SITE_ORIGIN}${page.path}`,
  description: page.softwareDescription,
  applicationCategory: 'UtilitiesApplication',
  applicationSubCategory: 'File Management',
  operatingSystem: page.operatingSystem,
  downloadUrl: page.downloadUrl,
  installUrl: page.installUrl,
  screenshot: `${SITE_ORIGIN}/images/showcase/windows-original/1.webp`,
  offers: [
    {
      '@type': 'Offer',
      name: 'Free',
      price: '0',
      priceCurrency: 'USD',
      description: 'Free tier with 50 AI renames.',
    },
    {
      '@type': 'Offer',
      name: 'Zush Pro',
      price: '10',
      priceCurrency: 'USD',
      description: 'One-time purchase. 10,000 AI renames plus BYOK support.',
    },
  ],
  featureList: page.features,
};
---

<BaseLayout
  seo={seo}
  forceOS="windows"
  chromeBasePath="/windows"
  disableTopOffset
  jsonLd={[
    softwareJsonLd,
    buildFeatureBreadcrumbJsonLd(page.breadcrumbLabel, page.path),
    buildFAQPageJsonLd(page.faqs),
  ]}
>
  <Hero
    client:load
    forceOS="windows"
    title={page.heroTitle}
    titleHighlight="Windows"
    subtitle={page.heroSubtitle}
    secondaryHref="#pricing"
  />
  <Videos client:visible autoplayWhenInView forceOS="windows" />
  <Features />
  <SupportedFormats />
  <DownloadCTA
    client:visible
    forceOS="windows"
    title="Try Zush free on Windows"
    subtitle={page.ctaSubtitle}
  />
  <WhyZush client:visible forceOS="windows" platformSpecificCopy />
  <UseCases />
  <Pricing client:visible />
  <PlatformGuides platform="windows" />
  <FAQ
    client:visible
    items={page.faqs}
    appendDefaultItems
    description="Everything you need to know about Zush for Windows and the rest of the product."
  />
</BaseLayout>
