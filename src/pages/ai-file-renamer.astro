---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FeatureLandingPageShell from '@/components/FeatureLandingPage/FeatureLandingPageShell.astro';
import { getFeaturePageProps } from '@/utils/featurePageProps';
import AIFileRenamer from '@/views/FeaturePages/AIFileRenamer';
import { getSeoForPath } from '@/seo/config';
import { buildFeatureBreadcrumbJsonLd } from '@/utils/jsonLd';

const seo = getSeoForPath('/ai-file-renamer');
const featurePage = getFeaturePageProps(AIFileRenamer);
---

<BaseLayout seo={seo} jsonLd={[featurePage.jsonLd, buildFeatureBreadcrumbJsonLd(featurePage.h1, '/ai-file-renamer')]}>
  <FeatureLandingPageShell {...featurePage} />
</BaseLayout>
