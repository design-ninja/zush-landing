---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DownloadPage from '@/components/DownloadPage/DownloadPage.astro';
import { getSeoForPath, SITE_ORIGIN } from '@/seo/config';
import { WINDOWS_STORE_URL, MIN_WINDOWS_VERSION } from '@/constants';
import { buildFeatureBreadcrumbJsonLd } from '@/utils/jsonLd';

const seo = getSeoForPath('/download/windows');

const softwareJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  '@id': `${SITE_ORIGIN}/download/windows#software`,
  name: 'Zush for Windows',
  url: `${SITE_ORIGIN}/download/windows`,
  description:
    'AI-powered file renamer for Windows. Rename screenshots, PDFs, photos and documents with descriptive names. Distributed through the Microsoft Store with auto-updates.',
  applicationCategory: 'UtilitiesApplication',
  applicationSubCategory: 'File Management',
  operatingSystem: 'Windows 10, Windows 11',
  downloadUrl: WINDOWS_STORE_URL,
  installUrl: WINDOWS_STORE_URL,
  screenshot: `${SITE_ORIGIN}/images/screenshots/light/zush-main-interface.webp`,
  offers: [
    {
      '@type': 'Offer',
      name: 'Free',
      price: '0',
      priceCurrency: 'USD',
      description: 'Free tier with 50 AI renames.',
    },
    {
      '@type': 'Offer',
      name: 'Zush Pro',
      price: '10',
      priceCurrency: 'USD',
      description: 'One-time purchase. 10,000 AI renames plus BYOK support.',
    },
  ],
  featureList: [
    'AI-powered file renaming',
    'Folder monitoring',
    'Batch rename',
    'Custom prompts',
    'One-click revert',
    'Installed via Microsoft Store',
    'BYOK (Bring Your Own Key)',
  ],
};

const downloadPageProps = {
  os: 'windows' as const,
  eyebrow: 'Now on Microsoft Store',
  title: 'Zush for Windows — AI File Renamer',
  subtitle:
    'Rename screenshots, PDFs, photos and documents with AI on Windows. Installs from the Microsoft Store with automatic updates. Free for 50 renames, no signup.',
  primaryLabel: 'Get from Microsoft Store',
  secondaryHref: '/#pricing',
  secondaryLabel: 'See pricing',
  hint: `Free · No credit card required · ${MIN_WINDOWS_VERSION}`,
  heroImage: '/images/screenshots/light/zush-main-interface.webp',
  heroImageAlt: 'Zush main interface on Windows',
  features: [
    'AI-powered renaming for screenshots, PDFs, photos, documents',
    'Folder monitoring: renames new files automatically',
    'Batch rename with per-file regenerate',
    'Custom prompts for names and metadata tags',
    'One-click revert from the Activity log',
    'Distributed through Microsoft Store with auto-updates',
    '60+ languages and flexible date formats',
    'BYOK for unlimited use (Gemini, Groq, OpenAI, Claude)',
  ],
  requirements: [
    {
      title: 'Windows version',
      body: `Requires ${MIN_WINDOWS_VERSION}. Earlier versions are not supported by the Store package.`,
    },
    {
      title: 'Architecture',
      body: 'Runs on x64 PCs. ARM64 support ships via Windows on ARM emulation — a native ARM build is on the roadmap.',
    },
    {
      title: 'Internet',
      body: 'Required for AI analysis. Files themselves stay on your PC; only compact content previews are sent to the model.',
    },
  ],
  steps: [
    {
      title: 'Open Microsoft Store',
      body: 'Click Get from Microsoft Store — the page opens in the Store app on Windows, or in your browser elsewhere.',
    },
    {
      title: 'Install with one click',
      body: 'The Store handles install, signing and future updates. No separate installer or admin-only steps.',
    },
    {
      title: 'Launch and rename',
      body: 'Open Zush from the Start menu, drop files on the window, and apply AI-generated names.',
    },
  ],
  faqs: [
    {
      question: 'Why is Zush distributed through the Microsoft Store?',
      answer:
        'The Store handles installation, signing, and auto-updates for every user. No separate installer, no smart-screen prompts, no manual version bumps.',
    },
    {
      question: 'Does Zush for Windows have the same features as Mac?',
      answer:
        'Yes. Zush for Windows ships with the same AI rename flow, folder monitoring, custom prompts, one-click revert, and BYOK support. We keep feature parity between platforms.',
    },
    {
      question: 'Does it run on Windows on ARM?',
      answer:
        'The Store package runs on ARM via the built-in x64 emulation layer. A native ARM64 build is on our roadmap.',
    },
    {
      question: 'Can I bring my own AI API key?',
      answer:
        'Yes. PRO users can enable BYOK (Bring Your Own Key) with Gemini, Groq, OpenAI or Claude for unlimited processing — you pay the provider directly.',
    },
    {
      question: 'Where are my files sent?',
      answer:
        'Originals stay on your PC. For AI analysis, Zush sends a compressed image preview or extracted document text to our AI providers. Content is not stored after processing.',
    },
  ],
  crossLinkHref: '/download/mac',
  crossLinkLabel: 'Get Zush for Mac',
  crossLinkHint: 'Using a Mac?',
};
---

<BaseLayout
  seo={seo}
  jsonLd={[softwareJsonLd, buildFeatureBreadcrumbJsonLd('Download for Windows', '/download/windows')]}
>
  <DownloadPage {...downloadPageProps} />
</BaseLayout>
