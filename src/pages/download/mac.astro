---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DownloadPage from '@/components/DownloadPage/DownloadPage.astro';
import { getSeoForPath, SITE_ORIGIN } from '@/seo/config';
import { DOWNLOAD_URL, MIN_MACOS_VERSION } from '@/constants';
import { buildFeatureBreadcrumbJsonLd } from '@/utils/jsonLd';

const seo = getSeoForPath('/download/mac');

const softwareJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  '@id': `${SITE_ORIGIN}/download/mac#software`,
  name: 'Zush for Mac',
  url: `${SITE_ORIGIN}/download/mac`,
  description:
    'AI-powered file renamer for macOS. Rename screenshots, PDFs, photos and documents with descriptive names — works on Apple Silicon and Intel.',
  applicationCategory: 'UtilitiesApplication',
  applicationSubCategory: 'File Management',
  operatingSystem: 'macOS 14.0+',
  downloadUrl: DOWNLOAD_URL,
  screenshot: `${SITE_ORIGIN}/images/screenshots/light/zush-main-interface.webp`,
  offers: [
    {
      '@type': 'Offer',
      name: 'Free',
      price: '0',
      priceCurrency: 'USD',
      description: 'Free tier with 50 AI renames.',
    },
    {
      '@type': 'Offer',
      name: 'Zush Pro',
      price: '10',
      priceCurrency: 'USD',
      description: 'One-time purchase. 10,000 AI renames plus BYOK support.',
    },
  ],
  featureList: [
    'AI-powered file renaming',
    'Folder monitoring',
    'Batch rename',
    'Custom prompts',
    'One-click revert',
    'Apple Silicon & Intel support',
    'BYOK (Bring Your Own Key)',
  ],
};

const downloadPageProps = {
  os: 'mac' as const,
  eyebrow: 'Available for macOS',
  title: 'Zush for Mac — AI File Renamer',
  subtitle:
    'Rename screenshots, PDFs, photos and documents with AI on your Mac. Native app built for Apple Silicon and Intel. Free for 50 renames, no signup.',
  primaryLabel: 'Download .dmg for Mac',
  secondaryHref: '/#pricing',
  secondaryLabel: 'See pricing',
  hint: `Free · No credit card required · macOS ${MIN_MACOS_VERSION}`,
  heroImage: '/images/screenshots/light/zush-main-interface.webp',
  heroImageAlt: 'Zush main interface on macOS',
  features: [
    'AI-powered renaming for screenshots, PDFs, photos, documents',
    'Folder monitoring: renames new files automatically',
    'Batch rename with per-file regenerate',
    'Custom prompts for names and metadata tags',
    'One-click revert from the Activity log',
    'Native Apple Silicon and Intel build',
    '60+ languages and flexible date formats',
    'BYOK for unlimited use (Gemini, Groq, OpenAI, Claude)',
  ],
  requirements: [
    {
      title: 'macOS version',
      body: `Requires macOS ${MIN_MACOS_VERSION}. Older releases are not supported.`,
    },
    {
      title: 'Architecture',
      body: 'Universal binary — runs natively on Apple Silicon (M1/M2/M3/M4) and Intel Macs.',
    },
    {
      title: 'Internet',
      body: 'Required for AI analysis. Files themselves stay on your machine; only compact content previews are sent to the model.',
    },
  ],
  steps: [
    {
      title: 'Download the .dmg',
      body: 'Click Download to get the signed and notarized installer. No account required.',
    },
    {
      title: 'Drag Zush to Applications',
      body: 'Open the .dmg and drop Zush into your Applications folder.',
    },
    {
      title: 'Launch and rename',
      body: 'Open Zush from Launchpad, drop files on the window, and apply AI-generated names.',
    },
  ],
  faqs: [
    {
      question: 'Does Zush work on Apple Silicon?',
      answer:
        'Yes. Zush ships as a universal binary and runs natively on M1, M2, M3 and M4 Macs. Intel Macs running macOS 14+ are supported as well.',
    },
    {
      question: 'Is the app notarized by Apple?',
      answer:
        'Yes. The .dmg is code-signed and notarized, so Gatekeeper will open it without manual overrides on a supported macOS version.',
    },
    {
      question: 'Do you offer a Mac App Store version?',
      answer:
        'Yes, a Mac App Store build is available as well. The direct .dmg download above is the recommended way to get the latest release quickly.',
    },
    {
      question: 'Where are my files sent?',
      answer:
        'Originals stay on your Mac. For AI analysis, Zush sends a compressed image preview or extracted document text to our AI providers. Content is not stored after processing.',
    },
    {
      question: 'Can I switch to my own API key?',
      answer:
        'Yes. PRO users can enable BYOK (Bring Your Own Key) with Gemini, Groq, OpenAI or Claude for unlimited processing — you pay the provider directly.',
    },
  ],
  crossLinkHref: '/download/windows',
  crossLinkLabel: 'Get Zush for Windows',
  crossLinkHint: 'Using Windows?',
};
---

<BaseLayout
  seo={seo}
  jsonLd={[softwareJsonLd, buildFeatureBreadcrumbJsonLd('Download for Mac', '/download/mac')]}
>
  <DownloadPage {...downloadPageProps} />
</BaseLayout>
