---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FeatureLandingPageShell from '@/components/FeatureLandingPage/FeatureLandingPageShell.astro';
import { getFeaturePageProps, VIDEO_SCHEMA } from '@/utils/featurePageProps';
import AIScreenshotRenamer from '@/views/FeaturePages/AIScreenshotRenamer';
import { getSeoForPath } from '@/seo/config';
import { buildFeatureBreadcrumbJsonLd } from '@/utils/jsonLd';

const seo = getSeoForPath('/ai-screenshot-renamer');
const featurePage = getFeaturePageProps(AIScreenshotRenamer);
---

<BaseLayout seo={seo} jsonLd={[featurePage.jsonLd, VIDEO_SCHEMA, buildFeatureBreadcrumbJsonLd(featurePage.h1, '/ai-screenshot-renamer')]}>
  <FeatureLandingPageShell {...featurePage} />
</BaseLayout>
