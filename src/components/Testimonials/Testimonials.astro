---
import Heading from '@/components/Heading';
import StarRating from '@/components/StarRating';
import Text from '@/components/Text';
import { DEFAULT_LOCALE, type Locale } from '@/i18n/config';
import sectionHeaderStyles from '@/components/SectionHeader/SectionHeader.module.scss';
import styles from './Testimonials.module.scss';

interface Props {
  locale?: Locale;
}

const testimonials = [
  {
    name: 'Laura Bennett',
    role: 'Attorney',
    quote:
      'Most invoices I get are named invoice.pdf, scan 4.pdf, or some nonsense from the copier. I drop the billing folder into Zush and get names like 2026-05-12 Acme contract review invoice. I still check the list, but the boring part is gone.',
  },
  {
    name: 'Dr. Amir Khan',
    role: 'Clinic owner',
    quote:
      'I keep a separate de-identified archive for follow-up notes. With Offline AI, Zush can name scans by visit date and a short diagnosis phrase. It is not something I run blindly, but it cuts the typing way down.',
  },
  {
    name: 'Elena Morozova',
    role: 'Photographer',
    quote:
      'My Fuji files all start life as DSCF-something. Zush pulls the EXIF date, then adds plain words like Kyoto rain or Miller family porch. When I search an old drive, I do not have to remember the folder name anymore.',
  },
  {
    name: 'Marcus Lee',
    role: 'Video editor',
    quote:
      'B-roll used to be a guessing game: clip_001, export2, final maybe. Zush names clips by what is on screen plus the date. I still fix a few, but I spend a lot less time opening ten videos to find one shot.',
  },
];

const copyByLocale: Partial<Record<Locale, { title: string; description: string; stars: string }>> = {
  en: { title: 'What people say about', description: 'Customer feedback from people who use Zush to clean up messy folders.', stars: '5 out of 5 stars' },
  de: { title: 'Was Menschen über', description: 'Kundenfeedback von Menschen, die mit Zush chaotische Ordner aufräumen.', stars: '5 von 5 Sternen' },
  fr: { title: 'Ce que les clients disent de', description: 'Retours de clients qui utilisent Zush pour ranger leurs dossiers.', stars: '5 étoiles sur 5' },
  es: { title: 'Lo que los clientes dicen de', description: 'Opiniones de clientes que usan Zush para ordenar sus carpetas.', stars: '5 de 5 estrellas' },
  'pt-br': { title: 'O que os clientes dizem sobre', description: 'Feedback de clientes que usam o Zush para organizar pastas.', stars: '5 de 5 estrelas' },
  it: { title: 'Cosa dicono i clienti di', description: 'Feedback di clienti che usano Zush per riordinare le cartelle.', stars: '5 stelle su 5' },
  nl: { title: 'Wat klanten zeggen over', description: 'Feedback van klanten die Zush gebruiken om mappen op te ruimen.', stars: '5 van 5 sterren' },
  ja: { title: 'お客様の声：', description: 'Zush でフォルダを整理しているお客様からのフィードバックです。', stars: '5つ星中5つ星' },
  ko: { title: '고객들이 말하는', description: 'Zush로 폴더를 정리하는 고객들의 피드백입니다.', stars: '5점 만점에 5점' },
  'zh-cn': { title: '客户如何评价', description: '使用 Zush 整理文件夹的客户反馈。', stars: '5 星满分' },
};

const { locale = DEFAULT_LOCALE } = Astro.props as Props;
const copy = copyByLocale[locale] ?? copyByLocale.en!;
---

<section id='reviews' class={styles.Testimonials} aria-labelledby='testimonials-title'>
  <div class={styles.Testimonials__Container}>
    <div class={sectionHeaderStyles.SectionHeader}>
      <Heading id='testimonials-title' as='h2' align='center' className={sectionHeaderStyles.SectionHeader__Title}>
        {copy.title}<span class={`${styles.Testimonials__TitleBrand} brand-accent-text`}>Zush</span>
      </Heading>
      <Text as='p' size='lg' color='subtle' align='center' className={sectionHeaderStyles.SectionHeader__Description}>
        {copy.description}
      </Text>
    </div>

    <div class={styles.Testimonials__Grid}>
      {testimonials.map((testimonial) => (
        <article class={styles.TestimonialCard}>
          <StarRating className={styles.TestimonialCard__Stars} label={copy.stars} />
          <blockquote class={styles.TestimonialCard__Quote}>
            <Text as='p' size='sm'>{testimonial.quote}</Text>
          </blockquote>
          <footer class={styles.TestimonialCard__Author}>
            <Text as='p' size='sm' className={styles.TestimonialCard__Name}>{testimonial.name}</Text>
            <Text as='p' size='sm' color='subtle'>{testimonial.role}</Text>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>
