  locale?: Locale;
}

interface TestimonialsCopy {
  title: string;
  description: string;
  leaveReview: string;
  modalTitle: string;
  modalDescription: string;
  closeLabel: string;
  ratingLabel: string;
  starsLabel: (rating: number) => string;
  nameLabel: string;
  emailLabel: string;
  useCaseLabel: string;
  useCasePlaceholder: string;
  reviewLabel: string;
  reviewPlaceholder: string;
  cancel: string;
  send: string;
  sending: string;
  successTitle: string;
  successDescription: string;
  error: string;
  cardStarsLabel: string;
}

const testimonials = [
  {
    name: 'Laura Bennett',
    role: 'Attorney',
    quote:
      'Most invoices I get are named invoice.pdf, scan 4.pdf, or some nonsense from the copier. I drop the billing folder into Zush and get names like 2026-05-12 Acme contract review invoice. I still check the list, but the boring part is gone.',
  },
  {
    name: 'Dr. Amir Khan',
    role: 'Clinic owner',
    quote:
      'I keep a separate de-identified archive for follow-up notes. With Offline AI, Zush can name scans by visit date and a short diagnosis phrase. It is not something I run blindly, but it cuts the typing way down.',
  },
  {
    name: 'Elena Morozova',
    role: 'Photographer',
    quote:
      'My Fuji files all start life as DSCF-something. Zush pulls the EXIF date, then adds plain words like Kyoto rain or Miller family porch. When I search an old drive, I do not have to remember the folder name anymore.',
  },
  {
    name: 'Marcus Lee',
    role: 'Video editor',
    quote:
      'B-roll used to be a guessing game: clip_001, export2, final maybe. Zush names clips by what is on screen plus the date. I still fix a few, but I spend a lot less time opening ten videos to find one shot.',
  },
];

