---

<section id="reviews" class={styles.Testimonials} aria-labelledby="testimonials-title" data-testimonials>
  <div class={styles.Testimonials__Container}>
    <div class={sectionHeaderStyles.SectionHeader}>
      <Heading id="testimonials-title" as="h2" align="center" className={sectionHeaderStyles.SectionHeader__Title}>
        {copy.title}<span class={`${styles.Testimonials__TitleBrand} brand-accent-text`}>Zush</span>
      </Heading>
      <Text as="p" size="lg" color="subtle" align="center" className={sectionHeaderStyles.SectionHeader__Description}>
        {copy.description}
      </Text>
    </div>

    <div class={styles.Testimonials__Grid}>
      {testimonials.map((testimonial) => (
        <article class={styles.TestimonialCard}>
          <div class={styles.TestimonialCard__Stars} aria-label={copy.cardStarsLabel}>
            {Array.from({ length: 5 }).map(() => (
              <span aria-hidden="true">★</span>
            ))}
          </div>
          <blockquote class={styles.TestimonialCard__Quote}>
            <Text as="p" size="md">
              {testimonial.quote}
            </Text>
          </blockquote>
          <footer class={styles.TestimonialCard__Author}>
            <Text as="p" size="sm" className={styles.TestimonialCard__Name}>{testimonial.name}</Text>
            <Text as="p" size="sm" color="subtle">{testimonial.role}</Text>
          </footer>
        </article>
      ))}
    </div>

    <div class={styles.Testimonials__ReviewAction}>
      <Button as="button" variant="ghost" size="md" type="button" data-review-open>
        {copy.leaveReview}
      </Button>
    </div>
  </div>

  <dialog class={styles.ReviewModal} data-review-modal aria-labelledby="review-modal-title">
    <form
      class={styles.ReviewModal__Panel}
      data-review-form
      data-sending={copy.sending}
      data-success-title={copy.successTitle}
      data-success-description={copy.successDescription}
      data-error={copy.error}
      method="dialog"
    >
      <div class={styles.ReviewModal__Header}>
        <div>
          <Heading id="review-modal-title" as="h3" size="h3">{copy.modalTitle}</Heading>
          <Text as="p" size="sm" color="subtle" className={styles.ReviewModal__Description}>
            {copy.modalDescription}
          </Text>
        </div>
        <button class={styles.ReviewModal__Close} type="button" aria-label={copy.closeLabel} data-review-close>
          <X size={22} strokeWidth={2.1} aria-hidden="true" />
        </button>
      </div>

      <fieldset class={styles.ReviewModal__RatingField}>
        <legend class={styles.ReviewModal__RatingLegend}>{copy.ratingLabel}</legend>
        <div class={styles.ReviewModal__RatingStars} data-rating-stars>
          {[5, 4, 3, 2, 1].map((rating) => (
            <label class={styles.ReviewModal__RatingOption}>
              <input type="radio" name="rating" value={String(rating)} required={rating === 5} />
              <span aria-hidden="true">★</span>
              <span class={styles.ReviewModal__RatingLabel}>{copy.starsLabel(rating)}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <label class={styles.ReviewModal__Field}>
        <Text as="span" size="sm">{copy.nameLabel}</Text>
        <FormInput className={styles.ReviewModal__Input} name="name" type="text" autoComplete="name" maxLength={80} required />
      </label>

      <label class={styles.ReviewModal__Field}>
        <Text as="span" size="sm">{copy.emailLabel}</Text>
        <FormInput className={styles.ReviewModal__Input} name="email" type="email" autoComplete="email" maxLength={120} required />
      </label>

      <label class={styles.ReviewModal__Field}>
        <Text as="span" size="sm">{copy.useCaseLabel}</Text>
        <FormInput className={styles.ReviewModal__Input} name="useCase" type="text" maxLength={120} placeholder={copy.useCasePlaceholder} required />
      </label>

      <label class={styles.ReviewModal__Field}>
        <Text as="span" size="sm">{copy.reviewLabel}</Text>
        <textarea
          class={styles.ReviewModal__Textarea}
          name="review"
          rows="5"
          maxlength="1200"
          placeholder={copy.reviewPlaceholder}
          required
        ></textarea>
      </label>

      <label class={styles.ReviewModal__Honeypot} aria-hidden="true">
        Website
        <input name="website" type="text" tabindex="-1" autocomplete="off" />
      </label>

      <Text
        as="div"
        size="sm"
        color="subtle"
        className={styles.ReviewModal__Status}
        data-review-status
        data-empty="true"
        role="status"
        aria-live="polite"
      >
        <span class={styles.ReviewModal__StatusIcon} aria-hidden="true">
          <CheckCircle size={44} strokeWidth={2.1} />
        </span>
        <Heading as="h4" size="h4" align="center" className={styles.ReviewModal__StatusTitle}>
          <span data-review-status-title></span>
        </Heading>
        <span class={styles.ReviewModal__StatusMessage} data-review-status-message></span>
      </Text>

      <div class={styles.ReviewModal__Actions}>
        <Button as="button" variant="ghost" size="md" type="button" data-review-close>
          {copy.cancel}
        </Button>
        <Button as="button" variant="primary" size="md" type="submit">
          {copy.send}
        </Button>
      </div>
    </form>
  </dialog>
</section>

<script>
  const bindReviewModal = () => {
    document.querySelectorAll('[data-testimonials]').forEach((root) => {
      if (!(root instanceof HTMLElement) || root.dataset.reviewBound === 'true') return;

      const modal = root.querySelector('[data-review-modal]');
      const form = root.querySelector('[data-review-form]');
      const status = root.querySelector('[data-review-status]');
      const statusTitle = root.querySelector('[data-review-status-title]');
      const statusMessage = root.querySelector('[data-review-status-message]');
      const openButton = root.querySelector('[data-review-open]');
      const closeButtons = root.querySelectorAll('[data-review-close]');
      const submitButton = form instanceof HTMLFormElement
        ? form.querySelector('button[type="submit"]')
        : null;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

      if (!(modal instanceof HTMLDialogElement)
        || !(form instanceof HTMLFormElement)
        || !(status instanceof HTMLElement)
        || !(statusTitle instanceof HTMLElement)
        || !(statusMessage instanceof HTMLElement)
        || !(openButton instanceof HTMLButtonElement)
        || !(submitButton instanceof HTMLButtonElement)) {
        return;
      }

      root.dataset.reviewBound = 'true';

      const setStatus = (
        title: string,
        tone: 'neutral' | 'success' | 'error' = 'neutral',
        message = '',
      ) => {
        statusTitle.textContent = title;
        statusMessage.textContent = message;
        status.dataset.tone = tone;
        status.dataset.empty = title || message ? 'false' : 'true';
        if (tone === 'success') {
          form.dataset.state = 'success';
        } else {
          delete form.dataset.state;
        }
      };

      const closeModal = () => {
        setStatus('');
        if (!modal.open) return;

        if (prefersReducedMotion.matches) {
          modal.close();
          return;
        }

        modal.dataset.closing = 'true';
        window.setTimeout(() => {
          modal.close();
          delete modal.dataset.closing;
        }, 180);
      };

      openButton.addEventListener('click', () => {
        setStatus('');
        delete modal.dataset.closing;
        modal.showModal();
      });

      closeButtons.forEach((button) => {
        button.addEventListener('click', closeModal);
      });

      modal.addEventListener('click', (event) => {
        if (event.target === modal) closeModal();
      });

      modal.addEventListener('cancel', (event) => {
        event.preventDefault();
        closeModal();
      });

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        submitButton.disabled = true;
        setStatus(form.dataset.sending || 'Sending...');

        const formData = new FormData(form);
        const payload = Object.fromEntries(formData.entries());

        try {
          const response = await fetch('/api/review', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(payload),
          });

          if (!response.ok) {
            throw new Error(form.dataset.error || 'Could not send the review.');
          }

          form.reset();
          setStatus(
            form.dataset.successTitle || 'Thanks a lot!',
            'success',
            form.dataset.successDescription || 'After moderation, your review will appear on the site.',
          );
        } catch (error) {
          setStatus(error instanceof Error ? error.message : (form.dataset.error || 'Could not send the review.'), 'error');
        } finally {
          submitButton.disabled = false;
        }
      });
    });
  };

  bindReviewModal();
  document.addEventListener('astro:after-swap', bindReviewModal);
</script>
