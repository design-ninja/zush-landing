---
import { getImage } from 'astro:assets';
import ctaBackground from '@/assets/download-cta/try-zush-free-bg.webp';
import DownloadButton from '@/components/DownloadButton/DownloadButton';
import Heading from '@/components/Heading';
import Text from '@/components/Text';
import { getShortRequirements, type DownloadOS } from '@/utils/download';
import type { DownloadMenuCopy } from '@/i18n/copy';
import styles from './DownloadCTA.module.scss';

interface Props {
  title?: string;
  subtitle?: string;
  className?: string;
  forceOS?: DownloadOS;
  hintPrefix?: string;
  downloadLabel?: string;
  downloadMenu?: DownloadMenuCopy;
  includeOtherDownloadOS?: boolean;
}

const {
  title,
  subtitle = 'Batch rename files, monitor folders, and rename screenshots, design files, PDFs, photos, audio, videos, iWork, and Office documents by content.',
  className,
  forceOS,
  hintPrefix = 'Free · No credit card required',
  downloadLabel,
  downloadMenu,
  includeOtherDownloadOS = true,
} = Astro.props as Props;

const resolvedTitle = title ?? 'Try Zush free';
const downloadOS = forceOS ?? 'mac';
// Rendered as a plain <img> so the empty alt is serialized as alt="" — the
// Image component emits a bare `alt`, which some crawlers read as missing.
const background = await getImage({
  src: ctaBackground,
  width: 1600,
  height: 914,
  format: 'webp',
  quality: 78,
});
---

<section class:list={[styles.Section, className]}>
  <div class={styles.Container}>
    <div class={styles.Card}>
      <img
        src={background.src}
        width="1600"
        height="914"
        alt=""
        class={styles.Background}
        loading="lazy"
        decoding="async"
        aria-hidden="true"
      />
      <div class={styles.Content}>
        <Heading as="h2" className={styles.Title}>{resolvedTitle}</Heading>
        <Text as="p" className={styles.Subtitle} color="subtle">{subtitle}</Text>
        <div class={styles.Buttons}>
          <DownloadButton
            client:visible
            source="download-cta"
            size="lg"
            forceOS={forceOS}
            label={downloadLabel}
            menuCopy={downloadMenu}
            includeOtherOS={includeOtherDownloadOS}
          />
        </div>
        <Text as="p" size="xs" color="subtle" className={styles.Hint}>
          {hintPrefix} · {getShortRequirements(downloadOS)}
        </Text>
      </div>
    </div>
  </div>
</section>
