---
import Breadcrumbs from '@/components/Breadcrumbs';
import PillLink from '@/components/PillLink';
import WhyZush from '@/components/WhyZush';
import Features from '@/components/Features/Features.astro';
import Heading from '@/components/Heading';
import Hero from '@/components/Hero';
import Pricing from '@/components/Pricing/Pricing.astro';
import SupportedFormats from '@/components/SupportedFormats';
import UseCases from '@/components/UseCases';
import Videos from '@/components/Videos';
import DownloadCTA from '@/components/DownloadCTA/DownloadCTA.astro';
import CrossPlatformBanner from '@/components/CrossPlatformBanner/CrossPlatformBanner.astro';
import TrustSignals from '@/components/TrustSignals';
import { FileType2 } from 'lucide-react';
import type { FeatureLandingPageProps } from './FeatureLandingPage';
import { getUseCasesForCategory } from '@/data/featureContent';
import FeatureFAQ from './FeatureFAQ';
import { DEFAULT_LOCALE, getLocalizedPath, type Locale, type LocalizedRoute } from '@/i18n/config';
import { getCopy, type FeatureCopy } from '@/i18n/copy';
import styles from './FeatureLandingPage.module.scss';

interface LocalizedProps {
  locale?: Locale;
  localizedCopy?: FeatureCopy;
}

const {
  h1,
  h1Accent,
  definitionText,
  showcaseSlides,
  faqItems,
  relatedBlogPosts,
  relatedPages,
  category = 'general',
} = Astro.props as FeatureLandingPageProps & LocalizedProps;

const localizedProps = Astro.props as FeatureLandingPageProps & LocalizedProps;
const currentLocale = localizedProps.locale ?? DEFAULT_LOCALE;
const currentCopy = getCopy(currentLocale);
const pageCopy = localizedProps.localizedCopy;
const useCasesData = getUseCasesForCategory(category);
const heroSlides = pageCopy?.showcaseSlides ?? (currentLocale === DEFAULT_LOCALE ? showcaseSlides : currentCopy.home.showcaseSlides);
const breadcrumbItems = [
  { label: currentLocale === DEFAULT_LOCALE ? 'Home' : 'Zush', href: getLocalizedPath('/', currentLocale) },
  { label: pageCopy?.h1 ?? h1 },
];
const shouldRenderPdfDeepDive = currentLocale === DEFAULT_LOCALE && category === 'pdf';
const pdfNamingRecipes = [
  {
    title: 'Invoices',
    before: 'scan_001.pdf',
    after: 'Amazon Invoice 2026-03.pdf',
    detail: 'Vendor, document type, invoice period, and date keep accounting folders sortable.',
  },
  {
    title: 'Contracts',
    before: 'signed-final.pdf',
    after: 'Acme NDA Signed 2026-03-14.pdf',
    detail: 'Counterparty, agreement type, status, and date make legal PDFs easier to retrieve.',
  },
  {
    title: 'Statements',
    before: 'download (7).pdf',
    after: 'Chase Statement March 2026.pdf',
    detail: 'Institution and reporting period are pulled from the PDF instead of guessed from the download name.',
  },
  {
    title: 'Scanned receipts',
    before: 'IMG_20260310_scan.pdf',
    after: 'Home Depot Receipt March 10.pdf',
    detail: 'For image-only scans, AI vision reads visible page content when there is no embedded text layer.',
  },
];
const pdfComparisonRows = [
  {
    tool: 'Finder / File Explorer',
    bestFor: 'One-off manual renames',
    gap: 'You still have to open each PDF, read it, decide on a name, and repeat that for every file.',
  },
  {
    tool: 'Preview',
    bestFor: 'Reading, marking up, exporting, and signing PDFs on Mac',
    gap: 'Preview does not batch-generate content-aware filenames for invoices, contracts, scans, and statements.',
  },
  {
    tool: 'Adobe Acrobat',
    bestFor: 'OCR, editing, forms, signatures, and PDF review workflows',
    gap: 'Acrobat helps manage PDF content, but filename cleanup is still largely a separate manual workflow.',
  },
  {
    tool: 'Zush',
    bestFor: 'Turning weak PDF filenames into searchable document names',
    gap: 'Zush reads text layers or scanned pages, extracts entities and dates, then previews names before applying them.',
  },
];
---

<Breadcrumbs items={breadcrumbItems} />
<article class={styles.Page}>
  <Hero
    as='header'
    title={pageCopy?.h1 ?? h1}
    titleAccent={pageCopy?.accent ?? h1Accent}
    subtitle={pageCopy?.definitionText ?? definitionText}
    slides={heroSlides}
    compactTopSpacing
    buyLabel={currentCopy.home.buyPro}
    downloadLabel={currentCopy.header.download}
    downloadMenu={currentCopy.downloadMenu}
    trustSignals={currentCopy.home.trustSignals}
    client:visible
  />

  <Videos client:visible autoplayWhenInView copy={currentCopy.home.videos} />
  <Features title={currentCopy.home.featuresTitle} description={currentCopy.home.featuresDescription} copy={currentCopy.home.featureCards} />
  <SupportedFormats
    category={category}
    title={currentCopy.home.supportedFormats}
    imagesLabel={currentCopy.home.images}
    documentsLabel={currentCopy.home.documents}
  />
  <DownloadCTA
    title={currentCopy.home.downloadTitle}
    subtitle={currentCopy.home.downloadSubtitle}
    hintPrefix={currentCopy.home.downloadHintPrefix}
    downloadLabel={currentCopy.header.download}
    downloadMenu={currentCopy.downloadMenu}
  />
  <WhyZush copy={currentCopy.home.whyZush} />
  <CrossPlatformBanner locale={currentLocale} />
  <UseCases
    title={currentLocale === DEFAULT_LOCALE ? useCasesData.title : currentCopy.home.useCasesTitle}
    description={currentLocale === DEFAULT_LOCALE ? useCasesData.description : currentCopy.home.useCasesDescription}
    items={currentLocale === DEFAULT_LOCALE && useCasesData.items.length > 0 ? useCasesData.items : undefined}
    copy={currentLocale === DEFAULT_LOCALE ? undefined : currentCopy.home.useCases}
  />

  {shouldRenderPdfDeepDive && (
    <>
      <section class={styles.PdfDeepDive}>
        <div class={styles.Section__Container}>
          <div class={styles.PdfDeepDive__Header}>
            <p class={styles.PdfDeepDive__Eyebrow}>PDF naming workflows</p>
            <Heading as='h2' align='center'>
              Built for invoices, contracts, scans, and statements
            </Heading>
            <p class={styles.PdfDeepDive__Intro}>
              PDF cleanup is different from renaming photos or screenshots. The useful filename is usually hidden in
              the document text: vendor names, counterparties, dates, form numbers, billing periods, and signatures.
            </p>
          </div>

          <div class={styles.PdfScenarioGrid}>
            {pdfNamingRecipes.map((recipe) => (
              <article class={styles.PdfScenarioCard}>
                <div class={styles.PdfFileItem}>
                  <div class={styles.PdfFileItem__Preview} aria-hidden='true'>
                    <FileType2 size={26} strokeWidth={2.1} />
                    <span class={styles.PdfFileItem__Badge}>PDF</span>
                  </div>
                  <div class={styles.PdfFileItem__Content}>
                    <div class={styles.PdfFileItem__Before}>{recipe.before}</div>
                    <div class={styles.PdfFileItem__After}>{recipe.after}</div>
                  </div>
                </div>
                <h3 class={styles.PdfScenarioCard__Title}>{recipe.title}</h3>
                <p class={styles.PdfScenarioCard__Description}>{recipe.detail}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class={styles.PdfComparison}>
        <div class={styles.Section__Container}>
          <div class={styles.PdfDeepDive__Header}>
            <p class={styles.PdfDeepDive__Eyebrow}>Workflow comparison</p>
            <Heading as='h2' align='center'>
              Where Zush fits next to Finder, Preview, and Adobe Acrobat
            </Heading>
            <p class={styles.PdfDeepDive__Intro}>
              Zush does not replace PDF readers or editors. It fills the repetitive filename step after PDFs are
              downloaded, scanned, signed, exported, or received by email.
            </p>
          </div>

          <div class={styles.PdfComparisonTable}>
            <div class={styles.PdfComparisonTable__Head}>
              <span>Tool</span>
              <span>Best for</span>
              <span>Filename gap</span>
            </div>
            {pdfComparisonRows.map((row) => (
              <div class={styles.PdfComparisonTable__Row}>
                <strong>{row.tool}</strong>
                <span>{row.bestFor}</span>
                <span>{row.gap}</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    </>
  )}

  <section class={styles.Section}>
    <div class={styles.Section__Container}>
      <Heading as='h2' align='center' style={{ marginBottom: '3rem' }}>
        {pageCopy?.faqTitle ?? 'Frequently Asked Questions'}
      </Heading>
      <FeatureFAQ faqItems={pageCopy?.faqItems ?? faqItems} client:visible />
    </div>
  </section>

  <Pricing copy={currentCopy.pricing} />
  {currentLocale === DEFAULT_LOCALE && <TrustSignals />}

  {(relatedPages.length > 0 || relatedBlogPosts.length > 0) && (
    <section class={styles.Section}>
      <div class={styles.Section__Container}>
        {relatedPages.length > 0 && (
          <>
            <Heading as='h3' align='center' style={{ marginBottom: '2rem' }}>
              {pageCopy?.relatedToolsTitle ?? 'Related Tools'}
            </Heading>
            <div class={styles.RelatedLinks}>
              {relatedPages.map((page) => (
                <PillLink href={getLocalizedPath(page.href, currentLocale)} withArrow>{currentCopy.featurePages[page.href as LocalizedRoute]?.h1 ?? page.title}</PillLink>
              ))}
            </div>
          </>
        )}

        {currentLocale === DEFAULT_LOCALE && relatedBlogPosts.length > 0 && (
          <div class={relatedPages.length > 0 ? styles.RelatedSection : ''}>
            <Heading as='h3' align='center' style={{ marginBottom: '2rem' }}>
              {pageCopy?.relatedGuidesTitle ?? 'Related Guides'}
            </Heading>
            <div class={styles.RelatedLinks}>
              {relatedBlogPosts.map((post) => (
                <PillLink href={`/blog/${post.href}`} withArrow>{post.title}</PillLink>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>
  )}
</article>
