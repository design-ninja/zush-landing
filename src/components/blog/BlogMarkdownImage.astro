---
import { getShowcaseVideoBySrc, resolveShowcaseVideoMedia } from '@/data/showcaseMedia';

const { src = '', alt = '', ...props } = Astro.props;

if (typeof src !== 'string') {
  throw new Error('BlogMarkdownImage requires a string src');
}

const showcaseVideo = src.endsWith('.mp4') ? getShowcaseVideoBySrc(src) : undefined;
const themedScreenshot = getThemedScreenshot(src);

function getThemedScreenshot(src: string) {
  if (src.includes('/screenshots/light/')) {
    return {
      darkSrc: src.replace('/screenshots/light/', '/screenshots/dark/'),
      height: '1528',
      width: '1664',
    };
  }

  const macosShowcaseMatch = src.match(/^\/images\/showcase\/macos\/(.+)-light\.webp$/);
  if (macosShowcaseMatch) {
    return {
      darkSrc: `/images/showcase/macos/${macosShowcaseMatch[1]}-dark.webp`,
      height: '1440',
      width: '2560',
    };
  }

  return undefined;
}
---

{
  showcaseVideo ? (
    <figure class='markdown-figure markdown-figure--video'>
      <a
        aria-label={`${alt || showcaseVideo.title}. Open video in a new tab`}
        class='markdown-video-link markdown-video-link--light'
        data-autoplay-video='true'
        data-video-label={alt || showcaseVideo.title}
        data-video-poster={resolveShowcaseVideoMedia(showcaseVideo, 'light').poster}
        data-video-src={resolveShowcaseVideoMedia(showcaseVideo, 'light').source}
        href={resolveShowcaseVideoMedia(showcaseVideo, 'light').source}
        rel='noopener noreferrer'
        target='_blank'
      >
        <img
          {...props}
          alt=''
          class='markdown-video-poster markdown-video-poster--light'
          decoding='async'
          height='720'
          loading='lazy'
          src={resolveShowcaseVideoMedia(showcaseVideo, 'light').poster}
          width='1280'
        />
        <span class='markdown-video-badge'>Open video</span>
      </a>
      <a
        aria-label={`${alt || showcaseVideo.title}. Open video in a new tab`}
        class='markdown-video-link markdown-video-link--dark'
        data-autoplay-video='true'
        data-video-label={alt || showcaseVideo.title}
        data-video-poster={resolveShowcaseVideoMedia(showcaseVideo, 'dark').poster}
        data-video-src={resolveShowcaseVideoMedia(showcaseVideo, 'dark').source}
        href={resolveShowcaseVideoMedia(showcaseVideo, 'dark').source}
        rel='noopener noreferrer'
        target='_blank'
      >
        <img
          {...props}
          alt=''
          class='markdown-video-poster markdown-video-poster--dark'
          decoding='async'
          height='720'
          loading='lazy'
          src={resolveShowcaseVideoMedia(showcaseVideo, 'dark').poster}
          width='1280'
        />
        <span class='markdown-video-badge'>Open video</span>
      </a>
      {alt && <figcaption>{alt}</figcaption>}
    </figure>
  ) : themedScreenshot ? (
    <figure class='markdown-figure'>
      <img
        {...props}
        alt={alt}
        class='markdown-image markdown-image--screenshot markdown-image--light'
        decoding='async'
        height={themedScreenshot.height}
        loading='lazy'
        src={src}
        width={themedScreenshot.width}
      />
      <img
        {...props}
        alt={alt}
        aria-hidden='true'
        class='markdown-image markdown-image--screenshot markdown-image--dark'
        decoding='async'
        height={themedScreenshot.height}
        loading='lazy'
        src={themedScreenshot.darkSrc}
        width={themedScreenshot.width}
      />
      {alt && <figcaption>{alt}</figcaption>}
    </figure>
  ) : (
    <figure class='markdown-figure'>
      <img
        {...props}
        alt={alt}
        class='markdown-image'
        decoding='async'
        loading='lazy'
        src={src}
      />
      {alt && <figcaption>{alt}</figcaption>}
    </figure>
  )
}
