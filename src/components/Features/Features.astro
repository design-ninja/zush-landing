---
import {
  FolderSync,
  Sparkles,
  History,
  Tag,
  MessageSquareText,
  KeyRound,
  Bot,
  LayoutTemplate,
  Blocks,
  WandSparkles,
} from 'lucide-react';
import Heading from '@/components/Heading';
import Text from '@/components/Text';
import { DEFAULT_FEATURE_CARDS_COPY, type FeatureCardsCopy } from '@/i18n/copy';
import BentoCard from './BentoCard.astro';
import SmartBatchRenameVisual from './SmartBatchRenameVisual';
import FeatureAnimation from './FeatureAnimation';
import styles from './Features.module.scss';

interface Props {
  title?: string;
  description?: string;
  copy?: FeatureCardsCopy;
  compactTopSpacing?: boolean;
  eagerVisuals?: boolean;
}

const {
  title = 'Zush Features',
  description = 'One desktop file renamer for batch renaming screenshots, design files, PDFs, photos, audio, videos, documents, and messy mixed folders',
  copy = DEFAULT_FEATURE_CARDS_COPY,
  compactTopSpacing = false,
  eagerVisuals = false,
} = Astro.props as Props;
const titleParts = title.split('Zush');
const className = [styles.Features, compactTopSpacing ? styles.Features_compactTopSpacing : '']
  .filter(Boolean)
  .join(' ');
---

<section id='features' class={className} data-scroll-reveal-skip>
  <div class={styles.Features__Container}>
    <div class={styles.SectionHeader ?? ''} style='text-align: center; margin-bottom: 2rem; max-width: 50rem; margin-left: auto; margin-right: auto;'>
      <Heading as='h2' align='center' style={{ marginBottom: '1.25rem' }}>
        {titleParts[0]}{titleParts.length > 1 ? <span class={styles.Features__TitleAccent}>Zush</span> : null}{titleParts.slice(1).join('Zush')}
      </Heading>
      <Text as='p' size='lg' color='subtle' align='center' style={{ maxWidth: '35rem', marginLeft: 'auto', marginRight: 'auto', lineHeight: 1.6 }}>
        {description}
      </Text>
    </div>

    <div class={styles.BentoGrid}>
      <BentoCard
        title={copy.aiAnalysis.title}
        description={copy.aiAnalysis.description}
        icon={Sparkles}
      >
        <div class={styles.UI_BatchRename}>
          {
            eagerVisuals ? (
              <SmartBatchRenameVisual client:load />
            ) : (
              <SmartBatchRenameVisual client:visible />
            )
          }
        </div>
      </BentoCard>

      <BentoCard
        title={copy.customAiBlocks.title}
        description={copy.customAiBlocks.description}
        icon={WandSparkles}
        badge='NEW ✨ FREE'
        class={styles['BentoCard--wide']}
      >
        <div class={styles.UI_FeatureAnimation}>
          <div style='width: 100%; max-width: 24rem;'>
            {
              eagerVisuals ? (
                <FeatureAnimation kind='custom-ai-blocks' client:load />
              ) : (
                <FeatureAnimation kind='custom-ai-blocks' client:visible />
              )
            }
          </div>
        </div>
      </BentoCard>

      <BentoCard
        title={copy.foldersMonitoring.title}
        description={copy.foldersMonitoring.description}
        icon={FolderSync}
      >
        <div class={styles.UI_FeatureAnimation}>
          {
            eagerVisuals ? (
              <FeatureAnimation kind='folders' client:load />
            ) : (
              <FeatureAnimation kind='folders' client:visible />
            )
          }
        </div>
      </BentoCard>

      <BentoCard
        title={copy.smartMetadata.title}
        description={copy.smartMetadata.description}
        icon={Tag}
      >
        <div class={styles.UI_FeatureAnimation}>
          {
            eagerVisuals ? (
              <FeatureAnimation kind='metadata' client:load />
            ) : (
              <FeatureAnimation kind='metadata' client:visible />
            )
          }
        </div>
      </BentoCard>

      <BentoCard
        title={copy.renameHistory.title}
        description={copy.renameHistory.description}
        icon={History}
      >
        <div class={styles.UI_FeatureAnimation}>
          {
            eagerVisuals ? (
              <FeatureAnimation kind='history' client:load />
            ) : (
              <FeatureAnimation kind='history' client:visible />
            )
          }
        </div>
      </BentoCard>

      <BentoCard
        title={copy.templates.title}
        description={copy.templates.description}
        icon={LayoutTemplate}
      >
        <div class={styles.UI_FeatureAnimation}>
          {
            eagerVisuals ? (
              <FeatureAnimation kind='templates' client:load />
            ) : (
              <FeatureAnimation kind='templates' client:visible />
            )
          }
        </div>
      </BentoCard>

      <BentoCard
        title={copy.namingBlocks.title}
        description={copy.namingBlocks.description}
        icon={Blocks}
      >
        <div class={styles.UI_FeatureAnimation}>
          {
            eagerVisuals ? (
              <FeatureAnimation kind='naming-blocks' client:load />
            ) : (
              <FeatureAnimation kind='naming-blocks' client:visible />
            )
          }
        </div>
      </BentoCard>

      <BentoCard
        title={copy.customPrompts.title}
        description={copy.customPrompts.description}
        icon={MessageSquareText}
      >
        <div class={styles.UI_FeatureAnimation}>
          {
            eagerVisuals ? (
              <FeatureAnimation kind='prompts' client:load />
            ) : (
              <FeatureAnimation kind='prompts' client:visible />
            )
          }
        </div>
      </BentoCard>

      <BentoCard
        title={copy.byok.title}
        description={copy.byok.description}
        icon={KeyRound}
        badge='PRO 🌟'
      >
        <div class={styles.UI_FeatureAnimation}>
          {
            eagerVisuals ? (
              <FeatureAnimation kind='byok' client:load />
            ) : (
              <FeatureAnimation kind='byok' client:visible />
            )
          }
        </div>
      </BentoCard>

      <BentoCard
        title={copy.offlineAi.title}
        description={copy.offlineAi.description}
        icon={Bot}
        badge='PRO 🌟'
        class={styles['BentoCard--wide']}
      >
        <div class={styles.UI_FeatureAnimation}>
          <div style='width: 100%; max-width: 24rem;'>
            {
              eagerVisuals ? (
                <FeatureAnimation kind='offline-ai' client:load />
              ) : (
                <FeatureAnimation kind='offline-ai' client:visible />
              )
            }
          </div>
        </div>
      </BentoCard>
    </div>
  </div>
</section>
