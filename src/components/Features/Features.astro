---
import {
  FolderSync,
  Sparkles,
  Sliders,
  History,
  Tag,
  Folder,
  Plus,
  Layers,
  Check,
  MessageSquareText,
  KeyRound,
  Bot,
} from 'lucide-react';
import Heading from '@/components/Heading';
import Text from '@/components/Text';
import { DEFAULT_FEATURE_CARDS_COPY, type FeatureCardsCopy } from '@/i18n/copy';
import sunsetThumb from '@/assets/features/sunset_thumb.png';
import glitchThumb from '@/assets/features/glitch_thumb.png';
import BentoCard from './BentoCard.astro';
import styles from './Features.module.scss';

interface Props {
  title?: string;
  description?: string;
  copy?: FeatureCardsCopy;
}

const {
  title = 'How Zush AI Renames Your Files',
  description = 'Powerful features packed into a simple, elegant interface',
  copy = DEFAULT_FEATURE_CARDS_COPY,
} = Astro.props as Props;
const currentYear = new Date().getFullYear();
const titleParts = title.split('Zush');
---

<section id='features' class={styles.Features}>
  <div class={styles.Features__Container}>
    <div class={styles.SectionHeader ?? ''} style='text-align: center; margin-bottom: 2rem; max-width: 50rem; margin-left: auto; margin-right: auto;'>
      <Heading as='h2' align='center' style={{ marginBottom: '1.25rem' }}>
        {titleParts[0]}{titleParts.length > 1 ? <span class={styles.Features__TitleAccent}>Zush</span> : null}{titleParts.slice(1).join('Zush')}
      </Heading>
      <Text as='p' size='lg' color='subtle' align='center' style={{ maxWidth: '35rem', marginLeft: 'auto', marginRight: 'auto', lineHeight: 1.6 }}>
        {description}
      </Text>
    </div>

    <div class={styles.BentoGrid}>
      <BentoCard
        title={copy.aiAnalysis.title}
        description={copy.aiAnalysis.description}
        icon={Sparkles}
      >
        <div class={styles.UI_Analysis}>
          <div class={styles.UI_Analysis__Preview}>
            <img
              src={sunsetThumb.src}
              alt='Sunset'
              width={64}
              height={64}
              loading='lazy'
              decoding='async'
            />
          </div>
          <div class={styles.UI_Analysis__Content}>
            <span class={styles.UI_Analysis__OldName}>{`Screenshot ${currentYear}-03-15 at 19.45.22.png`}</span>
            <span class={styles.UI_Analysis__NewName}>{copy.analysisNewName}</span>
          </div>
        </div>
      </BentoCard>

      <BentoCard
        title={copy.foldersMonitoring.title}
        description={copy.foldersMonitoring.description}
        icon={FolderSync}
      >
        <div class={styles.UI_Monitoring}>
          <div class={styles.UI_Monitoring__List}>
            <div class={styles.UI_Monitoring__Item}>
              <div class={styles.UI_Monitoring__FolderInfo}>
                <div class={styles.UI_Monitoring__Icon}>
                  <Folder size={16} />
                </div>
                <span>~/Desktop</span>
              </div>
            </div>
            <div class={styles.UI_Monitoring__Item}>
              <div class={styles.UI_Monitoring__FolderInfo}>
                <div class={styles.UI_Monitoring__Icon}>
                  <Folder size={16} />
                </div>
                <span>~/Projects/Design/Assets</span>
              </div>
            </div>
          </div>
          <div class={styles.UI_Monitoring__Add}>
            <Plus size={16} /> {copy.addFolder}
          </div>
        </div>
      </BentoCard>

      <BentoCard
        title={copy.batchRename.title}
        description={copy.batchRename.description}
        icon={Layers}
      >
        <div class={styles.UI_Batch}>
          <div class={styles.UI_Batch__List}>
            <div class={styles.UI_Batch__Item}>
              <div class={styles.UI_Batch__Names}>
                <span class={styles.UI_Batch__OldName}>{`Screenshot ${currentYear}-02-21.png`}</span>
                <span class={styles.UI_Batch__NewName}>→ {copy.batchNewNames[0]}</span>
              </div>
              <div class={styles.UI_Batch__Check}>
                <Check size={14} />
              </div>
            </div>
            <div class={styles.UI_Batch__Item}>
              <div class={styles.UI_Batch__Names}>
                <span class={styles.UI_Batch__OldName}>notes-final-v3.docx</span>
                <span class={styles.UI_Batch__NewName}>→ {copy.batchNewNames[1]}</span>
              </div>
              <div class={styles.UI_Batch__Check}>
                <Check size={14} />
              </div>
            </div>
            <div class={styles.UI_Batch__Item}>
              <div class={styles.UI_Batch__Names}>
                <span class={styles.UI_Batch__OldName}>investor-update-final.pptx</span>
                <span class={styles.UI_Batch__NewName}>→ {copy.batchNewNames[2]}</span>
              </div>
              <div class={styles.UI_Batch__Check}>
                <Check size={14} />
              </div>
            </div>
          </div>
        </div>
      </BentoCard>

      <BentoCard
        title={copy.customPatterns.title}
        description={copy.customPatterns.description}
        icon={Sliders}
      >
        <div class={styles.UI_Patterns}>
          <div class={styles.UI_Patterns__Input}>
            <span class={styles.UI_Patterns__Var}>{`{Title}`}</span>
            <span class={styles.UI_Patterns__Sep}>_</span>
            <span class={styles.UI_Patterns__Var}>{`{Date}`}</span>
            <span class={styles.UI_Patterns__Sep}>_</span>
            <span class={styles.UI_Patterns__Var}>{`{Category}`}</span>
          </div>
          <div class={styles.UI_Patterns__Preview}>
            {`Project_Zush_${currentYear}-03-20_Design.png`}
          </div>
        </div>
      </BentoCard>

      <BentoCard
        title={copy.smartMetadata.title}
        description={copy.smartMetadata.description}
        icon={Tag}
      >
        <div class={styles.UI_Metadata}>
          <div class={styles.UI_Metadata__File}>
            <div class={styles.UI_Metadata__Preview}>
              <img
                src={glitchThumb.src}
                alt='Glitch Art'
                width={64}
                height={64}
                loading='lazy'
                decoding='async'
              />
            </div>
            <div class={styles.UI_Metadata__FileInfo}>
              <span class={styles.UI_Metadata__FileName}>{copy.metadataFileName}</span>
              <span class={styles.UI_Metadata__FileMeta}>4.2 MB</span>
            </div>
          </div>
          <div class={styles.UI_Metadata__Tags}>
            {copy.metadataTags.map((tag) => <span>{tag}</span>)}
          </div>
        </div>
      </BentoCard>

      <BentoCard
        title={copy.renameHistory.title}
        description={copy.renameHistory.description}
        icon={History}
      >
        <div class={styles.UI_History}>
          <div class={styles.UI_History__Item}>
            <div class={styles.UI_History__Names}>
              <span class={styles.UI_History__OldName}>notes_FINAL_copy.docx</span>
              <span class={styles.UI_History__NewName}>→ {copy.historyNewNames[0]}</span>
            </div>
            <div class={styles.UI_History__Meta}>
              <span class={styles.UI_History__Time}>{copy.today}, 09:51</span>
              <span class={styles.UI_History__Undo}>{copy.undo}</span>
            </div>
          </div>
          <div class={`${styles.UI_History__Item} ${styles.UI_History__Item_faded}`}>
            <div class={styles.UI_History__Names}>
              <span class={styles.UI_History__OldName}>q1_report_export.xlsx</span>
              <span class={styles.UI_History__NewName}>→ {copy.historyNewNames[1]}</span>
            </div>
            <div class={styles.UI_History__Meta}>
              <span class={styles.UI_History__Time}>{copy.today}, 08:30</span>
            </div>
          </div>
        </div>
      </BentoCard>

      <BentoCard
        title={copy.customPrompts.title}
        description={copy.customPrompts.description}
        icon={MessageSquareText}
      >
        <div class={styles.UI_Prompts}>
          <div class={styles.UI_Prompts__Panel}>
            <div class={styles.UI_Prompts__Header}>
              <span class={styles.UI_Prompts__Label}>{copy.promptRules}</span>
              <span class={styles.UI_Prompts__Badge}>{copy.customBadge}</span>
            </div>
            <div class={styles.UI_Prompts__Editor}>
              <span class={styles.UI_Prompts__Text}>
                {copy.promptExample}
              </span>
            </div>
          </div>
        </div>
      </BentoCard>

      <BentoCard
        title={copy.byok.title}
        description={copy.byok.description}
        icon={KeyRound}
        badge='PRO 🌟'
      >
        <div class={styles.UI_BYOK}>
          <div class={styles.UI_BYOK__Input}>
            <span class={styles.UI_BYOK__Key}>{copy.apiKeyConnected}</span>
            <div class={styles.UI_BYOK__Icon}>
              <Check size={14} />
            </div>
          </div>
          <div class={styles.UI_BYOK__Providers}>
            <span>Gemini</span>
            <span>Groq</span>
            <span>OpenAI</span>
            <span>Claude</span>
          </div>
        </div>
      </BentoCard>

      <BentoCard
        title={copy.offlineAi.title}
        description={copy.offlineAi.description}
        icon={Bot}
        badge='PRO 🌟'
      >
        <div class={styles.UI_Ollama}>
          <div class={styles.UI_Ollama__Terminal}>
            <div class={styles.UI_Ollama__Header}>
              <span>{copy.terminal}</span>
            </div>
            <div class={styles.UI_Ollama__Body}>
              <div class={styles.UI_Ollama__Line}>
                <span class={styles.UI_Ollama__Prompt}>$</span>
                <span>ollama run qwen2.5vl:3b</span>
              </div>
              <div class={styles.UI_Ollama__Status}>
                <Check size={14} />
                <span>{copy.localModelReady}</span>
              </div>
            </div>
          </div>
        </div>
      </BentoCard>
    </div>
  </div>
</section>
