---
import type { LucideIcon } from 'lucide-react';
import Heading from '@/components/Heading';
import Text from '@/components/Text';
import styles from './Features.module.scss';

interface Props {
  title: string;
  description: string;
  icon: LucideIcon;
  class?: string;
  badge?: string;
  badgeTone?: 'success';
}

const { title, description, icon: Icon, class: className, badge, badgeTone } = Astro.props;
---

<div
  class={`${styles.BentoCard} ${className || ''}`}
  data-bento-card
>
  <div class={styles.BentoCard__Content}>
    <div class={styles.BentoCard__Header}>
      <div class={styles.BentoCard__IconWrapper}>
        <Icon size={24} />
      </div>
      <div class={styles.BentoCard__TitleRow}>
        <Heading as='h3' className={styles.BentoCard__Title}>
          {title}
        </Heading>
        {badge && (
          <span
            class={`${styles.BentoCard__Badge} ${
              badgeTone === 'success' ? styles.BentoCard__Badge_success : ''
            }`}
          >
            {badge}
          </span>
        )}
      </div>
    </div>
    <Text className={styles.BentoCard__Description} color='subtle'>
      {description}
    </Text>
  </div>
  <div class={styles.BentoCard__Visual}>
    <slot>
      <div class={styles.BentoCard__Placeholder} />
    </slot>
  </div>
</div>
