---
import {
  Camera,
  Clapperboard,
  FileSpreadsheet,
  FileText,
  FolderOpen,
  Layers,
  Monitor,
  Music,
  PenTool,
} from 'lucide-react';
import Heading from '@/components/Heading';
import Text from '@/components/Text';
import sectionHeaderStyles from '@/components/SectionHeader/SectionHeader.module.scss';
import useCaseStyles from '@/components/UseCases/UseCases.module.scss';
import {
  getLocalesForRoute,
  getLocalizedPath,
  isLocalizedRoute,
  type Locale,
} from '@/i18n/config';
import type { HomeWorkflowKey, HomeWorkflowsCopy } from '@/i18n/copy';

interface Props {
  copy: HomeWorkflowsCopy;
  locale: Locale;
}

const { copy, locale } = Astro.props;

const WORKFLOWS: Array<{
  key: HomeWorkflowKey;
  route: string;
  icon: typeof Monitor;
  color: 'purple' | 'blue' | 'green' | 'orange' | 'pink' | 'cyan';
}> = [
  { key: 'screenshots', route: '/rename-screenshots-with-ai', icon: Monitor, color: 'blue' },
  { key: 'pdfs', route: '/rename-pdf-with-ai', icon: FileText, color: 'orange' },
  { key: 'photos', route: '/rename-photos-with-ai', icon: Camera, color: 'green' },
  { key: 'documents', route: '/rename-documents-with-ai', icon: FileSpreadsheet, color: 'purple' },
  { key: 'organizer', route: '/ai-file-organizer', icon: FolderOpen, color: 'green' },
  { key: 'design', route: '/rename-design-files-with-ai', icon: PenTool, color: 'pink' },
  { key: 'videos', route: '/rename-videos-with-ai', icon: Clapperboard, color: 'cyan' },
  { key: 'audio', route: '/rename-audio-with-ai', icon: Music, color: 'purple' },
  { key: 'batch', route: '/batch-rename-files', icon: Layers, color: 'blue' },
];

const localizedHref = (route: string): string =>
  isLocalizedRoute(route) && getLocalesForRoute(route).includes(locale)
    ? getLocalizedPath(route, locale)
    : route;

const titleParts = copy.title.split('Zush');
---

<section class={useCaseStyles.UseCases} aria-labelledby="home-workflows-title">
  <div class={useCaseStyles.UseCases__Container}>
    <div class={sectionHeaderStyles.SectionHeader}>
      <Heading
        as="h2"
        align="center"
        id="home-workflows-title"
        className={sectionHeaderStyles.SectionHeader__Title}
      >
        {titleParts[0]}{titleParts.length > 1 ? <span class="brand-accent-text">Zush</span> : null}{titleParts.slice(1).join('Zush')}
      </Heading>
      <Text
        as="p"
        size="lg"
        color="subtle"
        align="center"
        className={sectionHeaderStyles.SectionHeader__Description}
      >
        {copy.description}
      </Text>
    </div>

    <div class={useCaseStyles.UseCases__Grid}>
      {WORKFLOWS.map(({ key, route, icon: Icon, color }) => (
        <a
          class={`${useCaseStyles.UseCaseCard} ${useCaseStyles[`UseCaseCard_${color}`]} ${useCaseStyles.UseCaseCard_linked}`}
          href={localizedHref(route)}
        >
          <div class={useCaseStyles.UseCaseCard__IconWrapper}>
            <Icon size={24} />
          </div>
          <Heading as="h3" size="h4" className={useCaseStyles.UseCaseCard__Title}>
            {copy.items[key].title}
          </Heading>
          <Text className={useCaseStyles.UseCaseCard__Description}>
            {copy.items[key].description}
          </Text>
        </a>
      ))}
    </div>
  </div>
</section>
