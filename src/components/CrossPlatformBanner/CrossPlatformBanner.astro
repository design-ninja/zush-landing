---
import { ArrowUpRight } from 'lucide-react';
import Heading from '@/components/Heading';
import Text from '@/components/Text';
import { DEFAULT_LOCALE, getLocalizedPath, type Locale } from '@/i18n/config';
import { getCrossPlatformBannerCopy } from '@/i18n/crossPlatform';
import styles from './CrossPlatformBanner.module.scss';

interface Props {
  locale?: Locale;
  hidePlatform?: 'mac' | 'windows';
}

const { locale = DEFAULT_LOCALE, hidePlatform } = Astro.props as Props;
const copy = getCrossPlatformBannerCopy(locale);
const macHref = getLocalizedPath('/mac', locale);
const windowsHref = getLocalizedPath('/windows', locale);
---

<section class={styles.CrossPlatformBanner}>
  <div class={styles.CrossPlatformBanner__Container}>
    <div class={styles.CrossPlatformBanner__Header}>
      <span class={styles.CrossPlatformBanner__Eyebrow}>{copy.eyebrow}</span>
      <Heading as='h2' className={styles.CrossPlatformBanner__Title}>{copy.title}</Heading>
      <Text as='p' color='subtle' className={styles.CrossPlatformBanner__Description}>
        {copy.description}
      </Text>
    </div>

    <div class={styles.CrossPlatformBanner__Cards} data-single={hidePlatform ? 'true' : undefined}>
      {hidePlatform !== 'mac' && (
        <a class={styles.PlatformCard} href={macHref} data-platform='mac'>
          <span class={styles.PlatformCard__Icon} aria-hidden='true'>
            <svg width='28' height='28' viewBox='0 0 24 24' fill='currentColor'>
              <path d='M16.365 1.43c0 1.14-.493 2.27-1.177 3.08-.744.9-1.99 1.57-2.987 1.57-.12 0-.23-.02-.3-.03-.01-.06-.04-.22-.04-.39 0-1.15.572-2.27 1.206-2.98.804-.94 2.142-1.64 3.248-1.68.03.13.05.28.05.43zm4.565 15.71c-.03.07-.463 1.58-1.518 3.12-.945 1.34-1.94 2.71-3.43 2.71-1.517 0-1.9-.88-3.63-.88-1.698 0-2.302.91-3.67.91-1.377 0-2.332-1.26-3.428-2.8-1.287-1.82-2.323-4.63-2.323-7.28 0-4.28 2.797-6.55 5.552-6.55 1.448 0 2.675.95 3.6.95.865 0 2.222-1.01 3.902-1.01.613 0 2.886.06 4.374 2.19-.13.09-2.383 1.37-2.383 4.19 0 3.26 2.854 4.42 2.955 4.45z'/>
            </svg>
          </span>
          <h3 class={styles.PlatformCard__Title}>{copy.macTitle}</h3>
          <p class={styles.PlatformCard__Description}>{copy.macDescription}</p>
          <span class={styles.PlatformCard__CTA}>
            {copy.macCta}
            <ArrowUpRight size={16} aria-hidden='true' />
          </span>
        </a>
      )}

      {hidePlatform !== 'windows' && (
        <a class={styles.PlatformCard} href={windowsHref} data-platform='windows'>
          <span class={styles.PlatformCard__Icon} aria-hidden='true'>
            <svg width='28' height='28' viewBox='0 0 24 24'>
              <path fill='#F25022' d='M0 3.449L9.75 2.1v9.451H0z'/>
              <path fill='#7FBA00' d='M10.949 1.94L24 0v11.4H10.949z'/>
              <path fill='#00A4EF' d='M0 12.6h9.75v9.451L0 20.699z'/>
              <path fill='#FFB900' d='M10.949 12.6H24V24l-13.051-1.801z'/>
            </svg>
          </span>
          <h3 class={styles.PlatformCard__Title}>{copy.windowsTitle}</h3>
          <p class={styles.PlatformCard__Description}>{copy.windowsDescription}</p>
          <span class={styles.PlatformCard__CTA}>
            {copy.windowsCta}
            <ArrowUpRight size={16} aria-hidden='true' />
          </span>
        </a>
      )}
    </div>
  </div>
</section>
