---
import DownloadButton from '@/components/DownloadButton';
import Button from '@/components/Button';
import styles from './DownloadPage.module.scss';

export interface DownloadPageRequirement {
  title: string;
  body: string;
}

export interface DownloadPageStep {
  title: string;
  body: string;
}

export interface DownloadPageFAQ {
  question: string;
  answer: string;
}

export interface Props {
  os: 'mac' | 'windows';
  eyebrow: string;
  title: string;
  subtitle: string;
  primaryLabel: string;
  secondaryHref: string;
  secondaryLabel: string;
  hint: string;
  heroImage: string;
  heroImageAlt: string;
  features: string[];
  requirements: DownloadPageRequirement[];
  steps: DownloadPageStep[];
  faqs: DownloadPageFAQ[];
  crossLinkHref: string;
  crossLinkLabel: string;
  crossLinkHint: string;
}

const {
  os,
  eyebrow,
  title,
  subtitle,
  primaryLabel,
  secondaryHref,
  secondaryLabel,
  hint,
  heroImage,
  heroImageAlt,
  features,
  requirements,
  steps,
  faqs,
  crossLinkHref,
  crossLinkLabel,
  crossLinkHint,
} = Astro.props;

const downloadSource = os === 'windows' ? 'download-page-windows' : 'download-page-mac';
---

<section class:list={[styles.Page]}>
  <div class={styles.Container}>
    <div class={styles.Hero}>
      <div>
        <span class={styles.Eyebrow}>
          {os === 'windows' ? (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M3 5.548l7.065-.966v6.822H3V5.548zm0 12.904l7.065.966v-6.822H3v5.856zm7.834 1.072L21 21V12.596h-10.166v6.928zM21 3l-10.166 1.476v6.928H21V3z"/>
            </svg>
          ) : (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.71 19.5C17.88 20.74 17 21.95 15.66 21.97C14.32 22 13.89 21.18 12.37 21.18C10.84 21.18 10.37 21.95 9.09997 22C7.78997 22.05 6.79997 20.68 5.95997 19.47C4.24997 17 2.93997 12.45 4.69997 9.39C5.56997 7.87 7.12997 6.91 8.81997 6.88C10.1 6.86 11.32 7.75 12.11 7.75C12.89 7.75 14.37 6.68 15.92 6.84C16.57 6.87 18.39 7.1 19.56 8.82C19.47 8.88 17.39 10.1 17.41 12.63C17.44 15.65 20.06 16.66 20.09 16.67C20.06 16.74 19.67 18.11 18.71 19.5ZM13 3.5C13.73 2.67 14.94 2.04 15.94 2C16.07 3.17 15.6 4.35 14.9 5.19C14.21 6.04 13.07 6.7 11.95 6.61C11.8 5.46 12.36 4.26 13 3.5Z"/>
            </svg>
          )}
          {eyebrow}
        </span>
        <h1 class={styles.Title}>{title}</h1>
        <p class={styles.Subtitle}>{subtitle}</p>
        <div class={styles.Buttons}>
          <DownloadButton
            client:load
            source={downloadSource}
            size="lg"
            label={primaryLabel}
            forceOS={os}
          />
          <Button as="link" href={secondaryHref} variant="ghost" size="lg">
            {secondaryLabel}
          </Button>
        </div>
        <p class={styles.Hint}>{hint}</p>
      </div>
      <div class={styles.HeroImage}>
        <img
          src={heroImage}
          alt={heroImageAlt}
          width={1200}
          height={800}
          loading="eager"
          decoding="async"
        />
      </div>
    </div>

    <div class={styles.Section}>
      <h2 class={styles.SectionTitle}>What you get</h2>
      <ul class={styles.Features}>
        {features.map((feature) => <li>{feature}</li>)}
      </ul>
    </div>

    <div class={styles.Section}>
      <h2 class={styles.SectionTitle}>System requirements</h2>
      <div class={styles.Requirements}>
        {requirements.map((req) => (
          <div class={styles.RequirementCard}>
            <h3 class={styles.CardTitle}>{req.title}</h3>
            <p class={styles.CardBody}>{req.body}</p>
          </div>
        ))}
      </div>
    </div>

    <div class={styles.Section}>
      <h2 class={styles.SectionTitle}>Install in three steps</h2>
      <div class={styles.Steps}>
        {steps.map((step, i) => (
          <div class={styles.StepCard}>
            <span class={styles.StepNumber}>{i + 1}</span>
            <h3 class={styles.CardTitle}>{step.title}</h3>
            <p class={styles.CardBody}>{step.body}</p>
          </div>
        ))}
      </div>
    </div>

    <div class={styles.Section}>
      <h2 class={styles.SectionTitle}>Frequently asked questions</h2>
      <div class={styles.FAQ}>
        {faqs.map((faq) => (
          <details class={styles.FAQItem}>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>

    <div class={styles.CrossLink}>
      <p>{crossLinkHint}</p>
      <a href={crossLinkHref}>{crossLinkLabel} →</a>
    </div>
  </div>
</section>
