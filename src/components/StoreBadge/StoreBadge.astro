---
import styles from './StoreBadge.module.scss';
import type { DownloadChannel, DownloadOS, DownloadSource } from '@/utils/download';

type StoreBadgeKind = 'app-store' | 'microsoft-store' | 'direct-dmg' | 'homebrew';

interface Props {
  kind: StoreBadgeKind;
  href: string;
  kicker: string;
  label: string;
  ariaLabel: string;
  size?: 'sm' | 'md' | 'lg';
  /** Optional store integration data attrs (used by app-store / microsoft-store openers). */
  dataStoreOs?: 'mac' | 'windows';
  dataStoreAppUrl?: string;
  dataStoreWebUrl?: string;
  /** Optional download tracking data attrs for static install/download links. */
  downloadOs?: DownloadOS;
  downloadSource?: DownloadSource;
  downloadChannel?: DownloadChannel;
  /** When true, opens in a new tab (defaults to true for store URLs, false for direct downloads). */
  external?: boolean;
}

const {
  kind,
  href,
  kicker,
  label,
  ariaLabel,
  size = 'md',
  dataStoreOs,
  dataStoreAppUrl,
  dataStoreWebUrl,
  downloadOs,
  downloadSource,
  downloadChannel,
  external = kind !== 'direct-dmg',
} = Astro.props as Props;

const uniqueId = Math.random().toString(36).slice(2, 9);
---

<a
  href={href}
  class={`${styles.StoreBadge} ${styles[`StoreBadge_${size}`]}`}
  data-kind={kind}
  aria-label={ariaLabel}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  data-store-os={dataStoreOs}
  data-store-app-url={dataStoreAppUrl}
  data-store-web-url={dataStoreWebUrl}
  data-download-os={downloadOs}
  data-download-source={downloadSource}
  data-download-channel={downloadChannel}
>
  <span class={styles.StoreBadge__Icon}>
    {kind === 'app-store' && (
      <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 800 800' aria-hidden='true'>
        <defs>
          <linearGradient
            id={`store-app-store-${uniqueId}`}
            gradientUnits='userSpaceOnUse'
            x1='400.05'
            y1='798.7717'
            x2='400.05'
            y2='-1.2283'
            gradientTransform='matrix(1 0 0 -1 0 798.7717)'
          >
            <stop offset='0' stop-color='#18BFFB' />
            <stop offset='1' stop-color='#2072F3' />
          </linearGradient>
        </defs>
        <path
          fill={`url(#store-app-store-${uniqueId})`}
