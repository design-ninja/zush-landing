---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero';
import Videos from '@/components/Videos';
import Features from '@/components/Features/Features.astro';
import SupportedFormats from '@/components/SupportedFormats';
import UseCases from '@/components/UseCases';
import Pricing from '@/components/Pricing/Pricing.astro';
import WhyZush from '@/components/WhyZush';
import DownloadCTA from '@/components/DownloadCTA/DownloadCTA.astro';
import FAQ from '@/components/FAQ';
import PlatformGuides from '@/components/PlatformGuides/PlatformGuides.astro';
import { PLATFORM_LANDING_CONTENT } from '@/data/platformLanding';
import { getSeoForPath, SITE_ORIGIN } from '@/seo/config';
import { buildFAQPageJsonLd, buildFeatureBreadcrumbJsonLd } from '@/utils/jsonLd';
import type { DownloadOS } from '@/utils/download';

interface Props {
  platform: Extract<DownloadOS, 'mac' | 'windows'>;
}

const { platform } = Astro.props as Props;
const page = PLATFORM_LANDING_CONTENT[platform];
const seo = getSeoForPath(page.path);
const platformLabel = platform === 'mac' ? 'Mac' : 'Windows';

const softwareJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  '@id': `${SITE_ORIGIN}${page.path}#software`,
  name: page.softwareName,
  url: `${SITE_ORIGIN}${page.path}`,
  description: page.softwareDescription,
  applicationCategory: 'UtilitiesApplication',
  applicationSubCategory: 'File Management',
  operatingSystem: page.operatingSystem,
  downloadUrl: page.downloadUrl,
  ...(platform === 'windows' ? { installUrl: page.installUrl } : {}),
  screenshot:
    platform === 'windows'
      ? `${SITE_ORIGIN}/images/showcase/windows-original/01-ai-rename-dropzone.webp`
      : `${SITE_ORIGIN}/images/screenshots/light/zush-main-interface.webp`,
  offers: [
    {
      '@type': 'Offer',
      name: 'Free',
      price: '0',
      priceCurrency: 'USD',
      description: 'Free tier with 50 AI renames.',
    },
    {
      '@type': 'Offer',
      name: 'Zush Pro',
      price: '10',
      priceCurrency: 'USD',
      description: 'One-time purchase. 10,000 AI renames plus BYOK and Offline AI mode.',
    },
  ],
  featureList: page.features,
};
---

<BaseLayout
  seo={seo}
  forceOS={platform}
  chromeBasePath={page.path}
  disableTopOffset
  jsonLd={[
    softwareJsonLd,
    buildFeatureBreadcrumbJsonLd(page.breadcrumbLabel, page.path),
    buildFAQPageJsonLd(page.faqs),
  ]}
>
  <Hero
    client:load
    forceOS={platform}
    title={page.heroTitle}
    titleHighlight={platformLabel}
    subtitle={page.heroSubtitle}
    secondaryHref="#pricing"
  />
  <Videos client:visible autoplayWhenInView forceOS={platform} />
  <Features />
  <SupportedFormats />
  <DownloadCTA
    forceOS={platform}
    title={`Try Zush free on ${platformLabel}`}
    subtitle={page.ctaSubtitle}
  />
  <WhyZush forceOS={platform} platformSpecificCopy />
  <UseCases />
  <Pricing />
  <PlatformGuides platform={platform} />
  <FAQ
    client:visible
    items={page.faqs}
    appendDefaultItems
    description={`Everything you need to know about Zush for ${platformLabel} and the rest of the product.`}
  />
</BaseLayout>
