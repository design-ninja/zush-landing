---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero';
import Tour from '@/components/Tour';
import Features from '@/components/Features/Features.astro';
import SupportedFormats from '@/components/SupportedFormats';
import Pricing from '@/components/Pricing/Pricing.astro';
import DownloadCTA from '@/components/DownloadCTA/DownloadCTA.astro';
import FAQ from '@/components/FAQ';
import PlatformGuides from '@/components/PlatformGuides/PlatformGuides.astro';
import PlatformSpecifics from '@/components/PlatformSpecifics/PlatformSpecifics.astro';
import CrossPlatformBanner from '@/components/CrossPlatformBanner/CrossPlatformBanner.astro';
import WindowsSeoSection from '@/components/WindowsSeoSection/WindowsSeoSection.astro';
import { PLATFORM_LANDING_CONTENT } from '@/data/platformLanding';
import { getPlatformLandingSections } from '@/data/platformLandingSections';
import { PLATFORM_SPECIFICS_CONTENT } from '@/data/platformSpecifics';
import { HOME_HERO_BATCH_RENAME_VIDEO, WINDOWS_SHOWCASE_SCREENSHOTS } from '@/data/showcaseMedia';
import macChangelogSource from '@/content/changelog.md?raw';
import windowsChangelogSource from '@/content/changelog.windows.md?raw';
import { parseLatestVersion } from '@/utils/version';
import { getSeoForPath, SITE_ORIGIN } from '@/seo/config';
import { buildFAQPageJsonLd, buildFeatureBreadcrumbJsonLd } from '@/utils/jsonLd';
import type { DownloadOS } from '@/utils/download';
import { DEFAULT_LOCALE, getLocalizedPath, type Locale } from '@/i18n/config';
import { getCopy } from '@/i18n/copy';
import { getPlatformFaqCopy } from '@/i18n/platformFaqs';
import { getPlatformSpecificsCopy } from '@/i18n/platformSpecifics';
import { getLocalizedPlatformSpecificsContent } from '@/i18n/platformSpecificsContent';
import { getLocalizedSeoForRoute } from '@/i18n/seo';
import { APP_CONFIG, APP_STORE_URL, WINDOWS_STORE_URL } from '@/constants';

interface Props {
  platform: Extract<DownloadOS, 'mac' | 'windows'>;
  locale?: Locale;
}

const { platform, locale = DEFAULT_LOCALE } = Astro.props as Props;
const copy = getCopy(locale);
const page = PLATFORM_LANDING_CONTENT[platform];
const localizedPage = copy.platforms[platform];
const localizedPlatformFaq = getPlatformFaqCopy(locale, platform, {
  description: localizedPage.faqDescription,
  items: localizedPage.faqs,
});
const faqItems = [...localizedPlatformFaq.items, ...copy.home.faqItems];
const seo = locale === DEFAULT_LOCALE ? getSeoForPath(page.path) : getLocalizedSeoForRoute(page.path, locale);
const platformLabel = platform === 'mac' ? 'Mac' : 'Windows';
const pagePath = getLocalizedPath(page.path, locale);
const platformSections = getPlatformLandingSections(platform, locale, copy);
const includeOtherDownloadOS = platform !== 'mac';
const shouldShowCrossPlatformBanner = platform !== 'mac';
const footerHidePlatform = platform === 'mac' ? 'windows' : undefined;

const specifics = getLocalizedPlatformSpecificsContent(
  platform,
  locale,
  copy,
  getPlatformSpecificsCopy(locale),
  PLATFORM_SPECIFICS_CONTENT[platform],
);
const memorySpec = specifics.systemRequirements.rows.find((row) => row.key === 'memory')?.value;
const storageSpec = specifics.systemRequirements.rows.find((row) => row.key === 'diskSpace')?.value;
const processorSpec = specifics.systemRequirements.rows.find((row) => row.key === 'processor')?.value;

const macVersion = parseLatestVersion(macChangelogSource) ?? undefined;
const windowsVersion = parseLatestVersion(windowsChangelogSource) ?? undefined;
const platformKeywords = platform === 'mac'
  ? [
      'file renamer for Mac',
      'batch rename files on Mac',
      'bulk rename files on Mac',
      'Mac file renamer',
      'file rename tool Mac',
      'AI renamer for Mac',
      'AI file renamer for Mac',
      'best AI file renamer for Mac',
      'AI file renamer Mac download',
      'rename files with AI on Mac',
      'Mac batch rename tool',
      'macOS file renamer',
      'offline AI renamer for Mac',
    ]
  : [
      'file renamer for Windows',
      'bulk rename files Windows 11',
      'bulk rename files Windows',
      'Windows 11 batch rename tool',
      'batch rename files Windows',
      'Windows file renamer',
      'Windows batch rename tool',
      'AI renamer for Windows',
      'AI file renamer for Windows',
      'AI file organizer for Windows',
      'automatic file organizer Windows',
      'rename files with AI on Windows',
      'content-aware file renamer Windows',
      'Windows File Explorer file renamer',
      'File Explorer batch rename AI',
      'PowerRename alternative',
      'Bulk Rename Utility alternative',
      'PDF renamer Windows',
      'screenshot renamer Windows',
      'photo renamer Windows',
      'video renamer Windows',
      'audio file renamer Windows',
      'design file renamer Windows',
      'searchable filenames Windows',
      'Windows Search filenames',
      'folder monitoring Windows',
      'Microsoft Store file renamer',
      'offline AI renamer for Windows',
      'local AI file renamer Windows',
    ];

const platformTrustSignals = platform === 'mac'
  ? ['Free 50 renames', 'No credit card', 'Preview + undo every batch']
  : copy.home.trustSignals;

const schemaAlternateNames = locale === DEFAULT_LOCALE
  ? platformKeywords
  : [
      localizedPage.softwareName,
      localizedPage.heroTitle,
      localizedPage.breadcrumbLabel,
    ];

const schemaKeywords = locale === DEFAULT_LOCALE
  ? platformKeywords
  : [
      localizedPage.softwareName,
      localizedPage.heroTitle,
      ...localizedPage.features.slice(0, 6),
    ];

const screenshotJsonLd = platform === 'windows'
  ? WINDOWS_SHOWCASE_SCREENSHOTS.slice(0, 6).map((item) => ({
      '@type': 'ImageObject',
      url: `${SITE_ORIGIN}${item.images.light}`,
      caption: `${item.title}: ${item.alt}`,
    }))
  : [
      {
        '@type': 'ImageObject',
        url: `${SITE_ORIGIN}/images/screenshots/light/zush-main-interface.webp`,
        caption: 'Zush for Mac AI file renamer interface',
      },
    ];

const softwareJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  '@id': `${SITE_ORIGIN}${pagePath}#software`,
  name: localizedPage.softwareName,
  alternateName: schemaAlternateNames,
  url: `${SITE_ORIGIN}${pagePath}`,
  description: localizedPage.softwareDescription,
  keywords: schemaKeywords.join(', '),
  applicationCategory: 'UtilitiesApplication',
  applicationSubCategory: 'File Management',
  operatingSystem: page.operatingSystem,
  ...(processorSpec ? { processorRequirements: processorSpec } : {}),
  ...(memorySpec ? { memoryRequirements: memorySpec } : {}),
  ...(storageSpec ? { storageRequirements: storageSpec } : {}),
  softwareVersion: APP_CONFIG.app_version,
  downloadUrl: page.downloadUrl,
  ...(platform === 'windows' ? { installUrl: page.installUrl } : {}),
  sameAs: [platform === 'mac' ? APP_STORE_URL : WINDOWS_STORE_URL],
  screenshot: screenshotJsonLd,
  offers: [
    {
      '@type': 'Offer',
      name: 'Free',
      price: '0',
      priceCurrency: 'USD',
      description: `Free tier with ${APP_CONFIG.free_tier_limit} AI renames.`,
    },
    {
      '@type': 'Offer',
      name: 'Zush PRO Monthly',
      price: '8',
      priceCurrency: 'USD',
      description: 'Monthly subscription. Unlimited PRO renames plus BYOK and Offline AI mode.',
    },
    {
      '@type': 'Offer',
      name: 'Zush PRO One-Time',
      price: '38',
      priceCurrency: 'USD',
      description: 'One-time purchase. Unlimited PRO renames plus BYOK and Offline AI mode.',
    },
  ],
  featureList: localizedPage.features,
};

const windowsVideoJsonLd = platform === 'windows' && locale === DEFAULT_LOCALE
  ? {
      '@context': 'https://schema.org',
      '@type': 'VideoObject',
      '@id': `${SITE_ORIGIN}${pagePath}#batch-rename-video`,
      name: 'Zush for Windows batch rename workflow',
      description:
        'A Zush for Windows demo showing File Explorer files analyzed by AI, reviewed in a batch rename list, and applied with undo history available.',
      thumbnailUrl: `${SITE_ORIGIN}${WINDOWS_SHOWCASE_SCREENSHOTS[0].images.light}`,
      contentUrl: `${SITE_ORIGIN}${WINDOWS_SHOWCASE_SCREENSHOTS[0].video?.light ?? '/videos/windows/zush-batch-rename.mp4'}`,
      embedUrl: `${SITE_ORIGIN}${pagePath}`,
      publisher: {
        '@type': 'Organization',
        name: 'Zush',
        url: SITE_ORIGIN,
      },
    }
  : null;

const howToJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  '@id': `${SITE_ORIGIN}${pagePath}#how-to`,
  name: locale === DEFAULT_LOCALE
    ? `How to rename files with AI on ${platformLabel}`
    : localizedPage.heroTitle,
  description:
    locale === DEFAULT_LOCALE
      ? platform === 'mac'
        ? 'Use Zush to rename files with AI on Mac: open the app, drop Finder files, review suggested names, and enable watched folders for ongoing cleanup.'
        : 'Use Zush to rename files with AI on Windows: open the app, drop File Explorer files, review suggested names, and enable watched folders for ongoing cleanup.'
      : localizedPage.heroSubtitle,
  totalTime: 'PT1M',
  tool: {
    '@type': 'HowToTool',
    name: 'Zush',
    url: `${SITE_ORIGIN}${pagePath}`,
  },
  step: specifics.quickstart.map((step, index) => ({
    '@type': 'HowToStep',
    position: index + 1,
    name: step.title,
    text: step.detail,
  })),
};

const jsonLdItems = [
  softwareJsonLd,
  howToJsonLd,
  buildFeatureBreadcrumbJsonLd(localizedPage.breadcrumbLabel, pagePath),
  buildFAQPageJsonLd(faqItems),
  ...(windowsVideoJsonLd ? [windowsVideoJsonLd] : []),
];
---

<BaseLayout
  seo={seo}
  locale={locale}
  forceOS={platform}
  footerHidePlatform={footerHidePlatform}
  chromeBasePath={pagePath}
  disableTopOffset
  jsonLd={jsonLdItems}
>
  <Hero
    client:load
    forceOS={platform}
    title={localizedPage.heroTitle}
    titleHighlight={platformLabel}
    subtitle={localizedPage.heroSubtitle}
    buyLabel={copy.home.buyPro}
    downloadLabel={copy.header.download}
    downloadMenu={copy.downloadMenu}
    includeOtherDownloadOS={includeOtherDownloadOS}
    trustSignals={platformTrustSignals}
    secondaryHref="#pricing"
    slides={copy.home.showcaseSlides}
    videoShowcase={platform === 'mac' ? HOME_HERO_BATCH_RENAME_VIDEO : undefined}
    macVersion={macVersion}
    windowsVersion={windowsVersion}
  />
  <Features
    title={platformSections.featuresTitle}
    description={platformSections.featuresDescription}
    copy={platformSections.featureCards}
    eagerVisuals
  />
  <Tour client:visible forceOS={platform} copy={copy.home.showcase} />
  {platform === 'windows' && locale === DEFAULT_LOCALE && <WindowsSeoSection />}
  <PlatformSpecifics platform={platform} locale={locale} />
  <SupportedFormats
    title={copy.home.supportedFormats}
    imagesLabel={copy.home.images}
    designLabel={copy.home.designLabel}
    documentsLabel={copy.home.documents}
    videosLabel={copy.home.videosLabel}
    audioLabel={copy.home.audioLabel}
  />
  <DownloadCTA
    forceOS={platform}
    title={localizedPage.ctaTitle}
    subtitle={localizedPage.ctaSubtitle}
    hintPrefix={copy.home.downloadHintPrefix}
    downloadLabel={copy.header.download}
    downloadMenu={copy.downloadMenu}
    includeOtherDownloadOS={includeOtherDownloadOS}
  />
  <Pricing copy={copy.pricing} />
  {shouldShowCrossPlatformBanner && <CrossPlatformBanner locale={locale} hidePlatform={platform} />}
  <PlatformGuides platform={platform} locale={locale} />
  <FAQ
    client:visible
    items={faqItems}
    title={copy.home.faqTitle}
    description={localizedPlatformFaq.description}
  />
</BaseLayout>
