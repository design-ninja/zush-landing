---
import DownloadButton from '@/components/DownloadButton/DownloadButton';
import LanguageSwitcher from '@/components/LanguageSwitcher/LanguageSwitcher.astro';
import type { DownloadOS } from '@/utils/download';
import {
  DEFAULT_LOCALE,
  LOCALES,
  getAlternatePaths,
  getLocaleBasePath,
  getLocalizedPath,
  isLocalizedRoute,
  type Locale,
} from '@/i18n/config';
import { getCopy } from '@/i18n/copy';
import appLinkStyles from '@/components/AppLink/AppLink.module.scss';
import buttonStyles from '@/components/Button/Button.module.scss';
import logoStyles from '@/components/Logo/Logo.module.scss';
import styles from './Header.module.scss';

interface Props {
  forceOS?: DownloadOS;
  basePath?: string;
  locale?: Locale;
  route?: string;
}

const {
  forceOS,
  basePath = '/',
  locale = DEFAULT_LOCALE,
  route = '/',
} = Astro.props as Props;
const localeCopy = getCopy(locale);
const copy = localeCopy.header;

const featuresHref = `${basePath}#features`;
const pricingHref = `${basePath}#pricing`;
const homeHref = getLocalizedPath('/', locale);
const blogHref = '/blog';
const shouldUseRouteLanguagePaths = isLocalizedRoute(route) && route !== '/404';
const languagePaths = shouldUseRouteLanguagePaths
  ? getAlternatePaths(route)
  : Object.fromEntries(
    LOCALES.map((item) => [item, getLocaleBasePath(item)]),
  ) as Record<Locale, string>;
const buyButtonClass = [
  buttonStyles.Button,
  buttonStyles.Button_ghost,
  buttonStyles.Button_sm,
  styles.Header__BuyBtn,
].join(' ');
const navLinkClass = [appLinkStyles.AppLink, styles.Header__Link].join(' ');
const logoClass = [appLinkStyles.AppLink, logoStyles.Logo].join(' ');
---

<nav class={styles.Header}>
  <div class={styles.Header__Container}>
    <a href={homeHref} class={logoClass} aria-label={copy.homeAria ?? 'Go to homepage'}>
      <picture>
        <source
          type='image/webp'
          srcset='/logo-80.webp 80w, /logo-96.webp 96w'
          sizes='(max-width: 768px) 40px, 48px'
        />
        <img
          src='/logo-96.png'
          srcset='/logo-80.png 80w, /logo-96.png 96w'
          sizes='(max-width: 768px) 40px, 48px'
          width='48'
          height='48'
          alt='Zush Logo'
          class={logoStyles.Logo__Icon}
          loading='eager'
          fetchpriority='high'
          decoding='async'
        />
      </picture>
      <span class={logoStyles.Logo__Text}>Zush</span>
    </a>

    <div class={styles.Header__Actions}>
      <a href={featuresHref} class={navLinkClass}>{copy.features}</a>
      <a href={pricingHref} class={navLinkClass}>{copy.pricing}</a>
      <a href={blogHref} class={navLinkClass}>{copy.blog}</a>

      <LanguageSwitcher locale={locale} paths={languagePaths} label={copy.language} />

      <button
        type='button'
        class={styles.Header__ThemeToggle}
        aria-label={copy.toggleTheme}
        data-theme-toggle
      >
        <svg
          class={`${styles.Header__ThemeIcon} ${styles.Header__ThemeIcon_sun}`}
          width='20'
          height='20'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2'
          stroke-linecap='round'
          stroke-linejoin='round'
          aria-hidden='true'
        >
          <circle cx='12' cy='12' r='4'></circle>
          <path d='M12 2v2'></path>
          <path d='M12 20v2'></path>
          <path d='m4.93 4.93 1.41 1.41'></path>
          <path d='m17.66 17.66 1.41 1.41'></path>
          <path d='M2 12h2'></path>
          <path d='M20 12h2'></path>
          <path d='m6.34 17.66-1.41 1.41'></path>
          <path d='m19.07 4.93-1.41 1.41'></path>
        </svg>
        <svg
          class={`${styles.Header__ThemeIcon} ${styles.Header__ThemeIcon_moon}`}
          width='20'
          height='20'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2'
          stroke-linecap='round'
          stroke-linejoin='round'
          aria-hidden='true'
        >
          <path d='M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9'></path>
        </svg>
      </button>

      <div class={styles.Header__Buttons}>
        <a href={pricingHref} class={buyButtonClass}>{copy.buyPro}</a>
        <DownloadButton
          client:load
          source='navbar'
          variant='black'
          size='sm'
          label={copy.download}
          menuCopy={localeCopy.downloadMenu}
          forceOS={forceOS}
          showDropdown={false}
          className={styles.Header__DownloadBtn}
        />
      </div>
    </div>
  </div>
</nav>
