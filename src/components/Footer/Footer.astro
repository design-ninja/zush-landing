---
import {
  APP_STORE_PROTOCOL_URL,
  APP_STORE_URL,
  GITHUB_RELEASES_URL,
  HOMEBREW_CASK_URL,
  LINKEDIN_COMPANY_URL,
  SUPPORT_EMAIL,
  WINDOWS_STORE_PROTOCOL_URL,
  WINDOWS_STORE_URL,
} from '@/constants';
import {
  DEFAULT_LOCALE,
  getLocalesForRoute,
  getLocalizedPath,
  type Locale,
  type LocalizedRoute,
} from '@/i18n/config';
import { getCopy } from '@/i18n/copy';
import appLinkStyles from '@/components/AppLink/AppLink.module.scss';
import headingStyles from '@/components/Heading/Heading.module.scss';
import textStyles from '@/components/Text/Text.module.scss';
import styles from './Footer.module.scss';

interface Props {
  locale?: Locale;
  hidePlatform?: 'mac' | 'windows';
  showTaaftBadge?: boolean;
}

const { locale = DEFAULT_LOCALE, hidePlatform, showTaaftBadge = false } = Astro.props as Props;
const copy = getCopy(locale).footer;
const shouldShowAppStore = hidePlatform !== 'mac';
const shouldShowMicrosoftStore = hidePlatform !== 'windows';

const sectionTitleClass = [headingStyles.Heading, headingStyles.Heading_h4, styles.Footer__SectionTitle].join(' ');
const descriptionClass = [textStyles.Text, textStyles.Text_subtle, styles.Footer__Description].join(' ');
const bottomTextClass = [textStyles.Text, textStyles.Text_base, styles.Footer__BottomText].join(' ');
const linkClass = [appLinkStyles.AppLink, styles.Footer__Link].join(' ');
const socialLinkClass = [appLinkStyles.AppLink, styles.Footer__SocialLink].join(' ');
const brandClass = [appLinkStyles.AppLink, styles.Footer__Brand].join(' ');
const footerHref = (route: LocalizedRoute) =>
  getLocalizedPath(route, getLocalesForRoute(route).includes(locale) ? locale : DEFAULT_LOCALE);
const appStoreVisibleLabel = `${copy.appStoreKicker} ${copy.appStoreLabel}`;
const microsoftStoreVisibleLabel = `${copy.microsoftStoreKicker} ${copy.microsoftStoreLabel}`;
const homebrewLabel = copy.productLinks.homebrew;
---

<footer class={styles.Footer} data-site-footer>
  <div class={styles.Footer__Container}>
    <div class={styles.Footer__Grid}>
      <div>
        <a href={footerHref('/')} class={brandClass}>Zush</a>
        <p class={descriptionClass}>
          {copy.description}
        </p>

        <div class={styles.Footer__StoreBadges}>
          {shouldShowAppStore && (
          <a
            href={APP_STORE_URL}
            target='_blank'
            rel='noopener noreferrer'
            class={`${appLinkStyles.AppLink} ${styles.Footer__AppStore}`}
            aria-label={`${appStoreVisibleLabel}: ${copy.appStoreAria}`}
            data-store-os='mac'
            data-store-app-url={APP_STORE_PROTOCOL_URL}
            data-store-web-url={APP_STORE_URL}
            data-download-os='mac'
            data-download-source='footer-appstore'
            data-download-channel='mac-app-store'
          >
            <span class={styles.Footer__StoreBadge}>
              <span class={styles.Footer__StoreBadgeIcon}>
                <svg
                  xmlns='http://www.w3.org/2000/svg'
                  width='24'
                  height='24'
                  viewBox='0 0 800 800'
                  aria-hidden='true'
                >
                  <defs>
                    <linearGradient
                      id='footer-app-store-grad'
                      gradientUnits='userSpaceOnUse'
                      x1='400.05'
                      y1='798.7717'
                      x2='400.05'
                      y2='-1.2283'
                      gradientTransform='matrix(1 0 0 -1 0 798.7717)'
                    >
                      <stop offset='0' stop-color='#18BFFB' />
                      <stop offset='1' stop-color='#2072F3' />
                    </linearGradient>
                  </defs>
                  <path
                    fill='url(#footer-app-store-grad)'
                    d='M638.4,0H161.6C72.3,0,0,72.3,0,161.6v476.9C0,727.7,72.3,800,161.6,800h476.9c89.2,0,161.6-72.3,161.6-161.6V161.6C800,72.3,727.7,0,638.4,0z'
                  ></path>
                  <path
                    fill='#FFFFFF'
                    d='M396.6,183.8l16.2-28c10-17.5,32.3-23.4,49.8-13.4s23.4,32.3,13.4,49.8L319.9,462.4h112.9c36.6,0,57.1,43,41.2,72.8H143c-20.2,0-36.4-16.2-36.4-36.4c0-20.2,16.2-36.4,36.4-36.4h92.8l118.8-205.9l-37.1-64.4c-10-17.5-4.1-39.6,13.4-49.8c17.5-10,39.6-4.1,49.8,13.4L396.6,183.8L396.6,183.8z M256.2,572.7l-35,60.7c-10,17.5-32.3,23.4-49.8,13.4S148,614.5,158,597l26-45C213.4,542.9,237.3,549.9,256.2,572.7L256.2,572.7z M557.6,462.6h94.7c20.2,0,36.4,16.2,36.4,36.4c0,20.2-16.2,36.4-36.4,36.4h-52.6l35.5,61.6c10,17.5,4.1,39.6-13.4,49.8c-17.5,10-39.6,4.1-49.8-13.4c-59.8-103.7-104.7-181.3-134.5-233c-30.5-52.6-8.7-105.4,12.8-123.3C474.2,318.1,509.9,380,557.6,462.6L557.6,462.6z'
                  ></path>
                </svg>
              </span>
              <span class={styles.Footer__StoreBadgeText}>
                <span class={styles.Footer__StoreBadgeKicker}>{copy.appStoreKicker}</span>
                <span class={styles.Footer__StoreBadgeLabel}>{copy.appStoreLabel}</span>
              </span>
            </span>
          </a>
          )}

          {shouldShowMicrosoftStore && (
          <a
            href={WINDOWS_STORE_URL}
            target='_blank'
            rel='noopener noreferrer'
            class={`${appLinkStyles.AppLink} ${styles.Footer__MicrosoftStore}`}
            aria-label={`${microsoftStoreVisibleLabel}: ${copy.microsoftStoreAria}`}
            data-store-os='windows'
            data-store-app-url={WINDOWS_STORE_PROTOCOL_URL}
            data-store-web-url={WINDOWS_STORE_URL}
            data-download-os='windows'
            data-download-source='footer-microsoft-store'
            data-download-channel='microsoft-store'
          >
            <span class={styles.Footer__StoreBadge}>
              <span class={styles.Footer__StoreBadgeIcon}>
                <svg
                  xmlns='http://www.w3.org/2000/svg'
                  width='24'
                  height='24'
                  viewBox='0 0 248 248'
                  aria-hidden='true'
                >
                  <defs>
                    <linearGradient id='footer-ms-store-grad-bg' gradientUnits='userSpaceOnUse' x1='109.37' y1='72.28' x2='151.79' y2='230.9'>
                      <stop offset='0' stop-color='#0669BC' />
                      <stop offset='0.7147' stop-color='#1B4779' />
                      <stop offset='1' stop-color='#233B61' />
                    </linearGradient>
                    <linearGradient id='footer-ms-store-grad-top' gradientUnits='userSpaceOnUse' x1='124' y1='7.2' x2='124' y2='43.5'>
                      <stop offset='0' stop-color='#30DAFF' />
                      <stop offset='1' stop-color='#0194D4' />
                    </linearGradient>
                    <linearGradient id='footer-ms-store-grad-bar' gradientUnits='userSpaceOnUse' x1='124' y1='2.54' x2='124' y2='14.08'>
                      <stop offset='0' stop-color='#1FB8FD' />
                      <stop offset='1' stop-color='#0591F2' />
                    </linearGradient>
                  </defs>
                  <path fill='url(#footer-ms-store-grad-bg)' d='M248,42c0-5.523-4.477-10-10-10H10C4.477,32,0,36.477,0,42v166c0,22.091,17.909,40,40,40h168c22.091,0,40-17.909,40-40V42z'></path>
                  <path fill='#F25022' d='M120,88H72v48h48V88z'></path>
                  <path fill='#7FBA00' d='M176,88h-48v48h48V88z'></path>
                  <path fill='#00A4EF' d='M120,144H72v48h48V144z'></path>
                  <path fill='#FFB900' d='M176,144h-48v48h48V144z'></path>
                  <path fill='url(#footer-ms-store-grad-top)' d='M56,16c0-8.837,7.163-16,16-16h104c8.837,0,16,7.163,16,16v24c0,4.418-3.582,8-8,8s-8-3.582-8-8V16H72v24c0,4.418-3.582,8-8,8s-8-3.582-8-8V16z'></path>
                  <path fill='url(#footer-ms-store-grad-bar)' d='M176,0H72v16h104V0z'></path>
                </svg>
              </span>
              <span class={styles.Footer__StoreBadgeText}>
                <span class={styles.Footer__StoreBadgeKicker}>{copy.microsoftStoreKicker}</span>
                <span class={styles.Footer__StoreBadgeLabel}>{copy.microsoftStoreLabel}</span>
              </span>
            </span>
          </a>
          )}
        </div>
      </div>

      <div>
        <h4 class={sectionTitleClass}>{copy.product}</h4>
        <ul class={styles.Footer__Links}>
          <li><a href={footerHref('/')} class={linkClass}>{copy.productLinks.fileRenamer}</a></li>
          <li><a href='/batch-rename-files' class={linkClass}>{copy.productLinks.batchRename}</a></li>
          <li><a href='/ai-file-organizer' class={linkClass}>{copy.productLinks.organizer}</a></li>
          <li><a href='/offline-ai-file-renamer' class={linkClass}>{copy.productLinks.offline}</a></li>
          <li><a href={footerHref('/mac')} class={linkClass}>{copy.productLinks.mac}</a></li>
          <li><a href={footerHref('/windows')} class={linkClass}>{copy.productLinks.windows}</a></li>
        </ul>
      </div>

      <div>
        <h4 class={sectionTitleClass}>{copy.byFileType}</h4>
        <ul class={styles.Footer__Links}>
          <li><a href={footerHref('/rename-pdf-with-ai')} class={linkClass}>{copy.productLinks.pdf}</a></li>
          <li><a href={footerHref('/rename-design-files-with-ai')} class={linkClass}>{copy.productLinks.design}</a></li>
          <li><a href={footerHref('/rename-documents-with-ai')} class={linkClass}>{copy.productLinks.documents}</a></li>
          <li><a href={footerHref('/rename-photos-with-ai')} class={linkClass}>{copy.productLinks.photos}</a></li>
          <li><a href={footerHref('/rename-videos-with-ai')} class={linkClass}>{copy.productLinks.videos}</a></li>
          <li><a href={footerHref('/rename-audio-with-ai')} class={linkClass}>{copy.productLinks.audio}</a></li>
          <li><a href={footerHref('/rename-screenshots-with-ai')} class={linkClass}>{copy.productLinks.screenshots}</a></li>
        </ul>
      </div>

      <div>
        <h4 class={sectionTitleClass}>{copy.resources}</h4>
        <ul class={styles.Footer__Links}>
          <li><a href={`${footerHref('/')}#pricing`} class={linkClass}>{copy.pricing}</a></li>
          <li><a href='/blog' class={linkClass}>{copy.blog}</a></li>
          <li><a href='/docs' class={linkClass}>{copy.productLinks.docs}</a></li>
          <li><a href='/about' class={linkClass}>{copy.productLinks.about}</a></li>
          <li><a href='/authors/kirill-isachenko' class={linkClass}>{copy.productLinks.author}</a></li>
          <li><a href='/changelog' class={linkClass}>{copy.changelog}</a></li>
          <li><a href={footerHref('/methodology')} class={linkClass}>{copy.methodology}</a></li>
        </ul>
      </div>

      <div>
        <h4 class={sectionTitleClass}>{copy.support}</h4>
        <ul class={styles.Footer__Links}>
          <li><a href={`mailto:${SUPPORT_EMAIL}`} class={linkClass}>{copy.contactSupport}</a></li>
          <li><a href='https://zush.canny.io' class={linkClass} target='_blank' rel='noopener noreferrer'>{copy.feedback}</a></li>
          <li><a href={footerHref('/terms-of-service')} class={linkClass}>{copy.terms}</a></li>
          <li><a href={footerHref('/privacy-policy')} class={linkClass}>{copy.privacy}</a></li>
          <li><a href={footerHref('/refund-policy')} class={linkClass}>{copy.refund}</a></li>
        </ul>
      </div>
    </div>

    <div class={styles.Footer__Bottom}>
      <p class={bottomTextClass}>© {new Date().getFullYear()} Zush</p>

      <div class={styles.Footer__Social}>
        <a
          href='https://x.com/zush_app'
          class={socialLinkClass}
          target='_blank'
          rel='noopener noreferrer'
          aria-label={copy.followX}
        >
          <svg width='24' height='24' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'>
            <path d='M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z' />
          </svg>
          <span class={styles.Footer__VisuallyHidden}>{copy.followX}</span>
        </a>

        <a
          href='https://www.youtube.com/@zushapp'
          class={socialLinkClass}
          target='_blank'
          rel='noopener noreferrer'
          aria-label={copy.followYouTube}
        >
          <svg width='24' height='24' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'>
            <path d='M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z' />
          </svg>
          <span class={styles.Footer__VisuallyHidden}>{copy.followYouTube}</span>
        </a>

        <a
          href={LINKEDIN_COMPANY_URL}
          class={socialLinkClass}
          target='_blank'
          rel='noopener noreferrer'
          aria-label={copy.followLinkedIn}
        >
          <svg width='24' height='24' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'>
            <path d='M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z' />
          </svg>
          <span class={styles.Footer__VisuallyHidden}>{copy.followLinkedIn}</span>
        </a>

        <a
          href='https://www.producthunt.com/products/zush'
          class={socialLinkClass}
          target='_blank'
          rel='noopener noreferrer'
          aria-label={copy.productHunt}
        >
          <svg width='24' height='24' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'>
            <path d='M13.604 8.4h-3.405V12h3.405a1.8 1.8 0 0 0 0-3.6zM12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zm1.604 14.4h-3.405V18H7.801V6h5.804a4.2 4.2 0 0 1 0 8.4z' />
          </svg>
          <span class={styles.Footer__VisuallyHidden}>{copy.productHunt}</span>
        </a>

        <a
          href={GITHUB_RELEASES_URL}
          class={socialLinkClass}
          target='_blank'
          rel='noopener noreferrer'
          aria-label={copy.followGitHub}
        >
          <svg width='24' height='24' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'>
            <path d='M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12' />
          </svg>
          <span class={styles.Footer__VisuallyHidden}>{copy.followGitHub}</span>
        </a>

        <a
          href={HOMEBREW_CASK_URL}
          class={socialLinkClass}
          target='_blank'
          rel='noopener noreferrer'
          aria-label={homebrewLabel}
        >
          <svg width='24' height='24' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'>
            <path d='M7.938 0a.214.214 0 0 0-.206.156c-.316 1.104.179 2.15.838 2.935.153.181.313.347.476.501a2.039 2.039 0 0 0-.665.02c-1.184.233-2.193.985-2.74 2.532a3.893 3.893 0 0 0-.2 1.466 1.565 1.565 0 0 0-1.156 1.504 1.59 1.59 0 0 0 1.227 1.541l.026 12.046c0 .195.1.377.264.482a.214.214 0 0 0 .008.005c.537.31 2.047.812 5.21.812 3.238 0 4.7-.678 5.181-1.04a.214.214 0 0 0 .008-.007.571.571 0 0 0 .206-.439c.002-.344.002-1.136.002-1.604a.143.143 0 0 1 .147-.144c.397.006.869.006 1.318.005a1.826 1.826 0 0 0 1.832-1.825v-5.804a1.826 1.826 0 0 0-1.825-1.826H16.56a.14.14 0 0 1-.143-.144V10.6h.007v-.001a1.573 1.573 0 0 0 1.356-1.556c0-.816-.627-1.489-1.424-1.563-.025-1.438-.437-2.126-.736-2.58a.214.214 0 0 0-.005-.007c-.364-.51-1.193-1.282-2.275-1.316-.503-.016-.842.124-1.125.254-.217.1-.42.177-.67.22.002-1.286.945-1.981.945-1.981a.214.214 0 0 0 .05-.298s-.087-.122-.21-.26c-.121-.136-.269-.294-.47-.378a.214.214 0 0 0-.079-.017.214.214 0 0 0-.145.055 4.308 4.308 0 0 0-.875 1.101 3.42 3.42 0 0 0-.133.273 3.497 3.497 0 0 0-.381-.846C9.794.978 9.063.436 8.017.016A.214.214 0 0 0 7.939 0zm.156.524c.85.378 1.43.83 1.79 1.403.274.438.426.962.484 1.584a3.07 3.07 0 0 0-.012.462 6.897 6.897 0 0 1-.168-.052 5.487 5.487 0 0 1-1.29-1.106c-.551-.657-.935-1.46-.804-2.291zM11.8 1.618c.07.054.141.101.212.18.034.039.032.04.058.073-.332.308-1.07 1.144-.952 2.453a.214.214 0 0 0 .222.195c.469-.017.782-.172 1.056-.299.273-.126.508-.228.931-.214.875.027 1.639.715 1.939 1.134.295.449.65 1 .663 2.36a1.66 1.66 0 0 0-.41.142 1.938 1.938 0 0 0-1.77-1.16 1.94 1.94 0 0 0-1.87 1.448 1.783 1.783 0 0 0-1.356-.64c-.484 0-.91.205-1.233.517a1.873 1.873 0 0 0-1.85-1.625c-.649 0-1.218.335-1.552.84a3.1 3.1 0 0 1 .157-.735c.51-1.437 1.355-2.045 2.42-2.254.367-.073.664-.011.99.095.325.106.671.262 1.094.342a.214.214 0 0 0 .252-.245c-.112-.67.073-1.266.336-1.744a3.71 3.71 0 0 1 .663-.863zM7.44 6.611a1.442 1.442 0 0 1 1.363 1.925.214.214 0 0 0 .168.283h.005a.214.214 0 0 0 .238-.146 1.373 1.373 0 0 1 2.613-.01.214.214 0 0 0 .417-.09 1.509 1.509 0 0 1 1.504-1.664c.678 0 1.249.445 1.442 1.056a.214.214 0 0 0 .259.143l.15-.04a.214.214 0 0 0 .051-.02 1.139 1.139 0 0 1 1.702.995 1.14 1.14 0 0 1-.985 1.131.214.214 0 0 0-.001 0 2.215 2.215 0 0 0-.485.126 10.65 10.65 0 0 1-1.176.365.214.214 0 0 0-.162.186 1.276 1.276 0 0 1-.146.478 2.07 2.07 0 0 0-.239 1.111l.001.151a.438.438 0 0 1-.16.36.665.665 0 0 1-.43.14.586.586 0 0 1-.588-.59.803.803 0 0 0-.38-.681.214.214 0 0 0-.002-.002c-.24-.145-.43-.37-.532-.636a.214.214 0 0 0-.207-.138 19.469 19.469 0 0 1-5.37-.6l-.003-.002a9.007 9.007 0 0 0-.838-.194h.003a1.16 1.16 0 0 1-.937-1.134c0-.619.488-1.118 1.101-1.14a.214.214 0 0 0 .204-.176 1.443 1.443 0 0 1 1.42-1.187zm8.549 4.106v.455c0 .314.259.573.572.573h1.329a1.397 1.397 0 0 1 1.397 1.397v5.804a1.396 1.396 0 0 1-1.402 1.396.214.214 0 0 0-.002 0c-.448.002-.918 0-1.31-.005a.573.573 0 0 0-.584.573c0 .468 0 1.262-.002 1.603a.214.214 0 0 0 0 .001c0 .042-.019.08-.05.107-.346.26-1.75.95-4.915.95-3.107 0-4.587-.52-4.99-.752a.143.143 0 0 1-.065-.118l-.025-11.955c.145.033.288.07.431.11a.214.214 0 0 0 .003 0c.115.031.246.064.383.097v10.37c0 .129.069.247.18.31.453.217 1.767.732 4.071.732 2.32 0 3.595-.626 4.022-.884a.357.357 0 0 0 .164-.3l.001-10.21c.267-.075.531-.158.792-.254zm-7.99.894a.493.493 0 0 1 .494.493v8.578a.493.493 0 0 1-.493.493.493.493 0 0 1-.494-.493v-8.578A.493.493 0 0 1 8 11.611zm8.652 1.14a.663.663 0 0 0-.662.662v5.208a.663.663 0 0 0 .662.662h1.14a.663.663 0 0 0 .662-.662v-5.209a.663.663 0 0 0-.662-.662zm0 .428h1.14a.233.233 0 0 1 .233.233v5.21a.233.233 0 0 1-.233.232h-1.14a.233.233 0 0 1-.233-.233v-5.209a.233.233 0 0 1 .233-.233z' />
          </svg>
          <span class={styles.Footer__VisuallyHidden}>{homebrewLabel}</span>
