---
import SectionHeader from '@/components/SectionHeader';
import Heading from '@/components/Heading';
import Text from '@/components/Text';
import buttonStyles from '@/components/Button/Button.module.scss';
import { PRO_PLAN, type Feature } from './constants';
import styles from './Pricing.module.scss';

const plan = PRO_PLAN;
const featureGroups = plan.features.reduce<Feature[][]>((groups, feature) => {
  if (groups.length === 0 || feature.groupBreakBefore) {
    groups.push([]);
  }

  groups[groups.length - 1].push(feature);
  return groups;
}, []);
const cardClass = [
  styles.PricingCard,
  plan.highlight ? styles.PricingCard_highlighted : '',
]
  .filter(Boolean)
  .join(' ');
const buttonClass = [
  buttonStyles.Button,
  buttonStyles.Button_primary,
  buttonStyles.Button_md,
].join(' ');
---

<section id="pricing" class={styles.Pricing}>
  <div class={styles.Pricing__Container}>
    <SectionHeader
      title="Pay once, use forever"
      description="No subscriptions, no hidden fees. Just a simple one-time purchase."
    />

    <div class={styles.Pricing__Single}>
      <div class={cardClass} id={plan.isPro ? 'pro' : undefined}>
        <div class={styles.PricingCard__Top}>
          <div class={styles.PricingCard__HeaderRow}>
            <div class={styles.PricingCard__Header}>
              <Heading as="h3" className={styles.PricingCard__Name}>
                {plan.name}
              </Heading>
              <Text
                as="p"
                size="sm"
                color="subtle"
                className={styles.PricingCard__Description}
              >
                {plan.description}
              </Text>
            </div>
          </div>

          <div class={styles.PricingCard__Price}>
            <div class={styles.PricingCard__PriceLeft}>
              <span class={styles.PricingCard__PriceValue}>{plan.price ?? '$10'}</span>
              {plan.billing && (
                <span class={styles.PricingCard__PricePeriod}>{plan.billing}</span>
              )}
            </div>
          </div>
        </div>

        <div class={styles.PricingCard__Features}>
          {featureGroups.map((group) => (
            <div class={styles.PricingCard__FeatureGroup}>
              {group.map((feature) => {
                const Icon = feature.icon;

                return (
                  <div class={styles.PricingCard__Feature}>
                    <div class={styles.PricingCard__FeatureIcon}>
                      <Icon size={24} />
                    </div>
                    <div>
                      <div class={styles.PricingCard__FeatureTitle}>
                        {feature.title}
                      </div>
                      <div class={styles.PricingCard__FeatureDesc}>
                        {feature.desc}
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          ))}
        </div>

        <div class={styles.PricingCard__ButtonWrapper}>
          <button
            type="button"
            class={buttonClass}
            data-paddle-checkout
            data-paddle-price-id={plan.paddlePriceId}
          >
            {plan.buttonText}
          </button>
          <Text
            as="p"
            size="sm"
            color="subtle"
            className={styles.PricingCard__ButtonHint}
          >
            14-day money-back guarantee • Secure via Paddle
          </Text>
        </div>
      </div>
    </div>
  </div>
</section>
