---
import Hero from '@/components/Hero';
import Tour from '@/components/Tour';
import Features from '@/components/Features/Features.astro';
import SupportedFormats from '@/components/SupportedFormats';
import CloudFolders from '@/components/CloudFolders';
import HomeBlogHighlights from '@/components/HomeBlogHighlights/HomeBlogHighlights.astro';
import HomeWorkflows from '@/components/HomeWorkflows/HomeWorkflows.astro';
import Pricing from '@/components/Pricing/Pricing.astro';
import FAQ from '@/components/FAQ';
import DownloadCTA from '@/components/DownloadCTA/DownloadCTA.astro';
import CrossPlatformBanner from '@/components/CrossPlatformBanner/CrossPlatformBanner.astro';
import EvidenceSignals from '@/components/EvidenceSignals/EvidenceSignals.astro';
import Testimonials from '@/components/Testimonials/Testimonials.astro';
import macChangelogSource from '@/content/changelog.md?raw';
import windowsChangelogSource from '@/content/changelog.windows.md?raw';
import { FREE_DOWNLOAD_BADGE_LABEL } from '@/constants';
import { HOME_HERO_BATCH_RENAME_VIDEO, WINDOWS_HERO_BATCH_RENAME_VIDEO } from '@/data/showcaseMedia';
import { parseLatestVersion } from '@/utils/version';
import type { Locale } from '@/i18n/config';
import type { LocaleCopy } from '@/i18n/copy';

interface Props {
  copy: LocaleCopy;
  locale: Locale;
  secondaryHref?: string;
}

const { copy, locale, secondaryHref } = Astro.props as Props;
const macVersion = parseLatestVersion(macChangelogSource) ?? undefined;
const windowsVersion = parseLatestVersion(windowsChangelogSource) ?? undefined;
const heroVideoShowcaseByOS = {
  mac: HOME_HERO_BATCH_RENAME_VIDEO,
  windows: WINDOWS_HERO_BATCH_RENAME_VIDEO,
};
const offlineBadge = {
  label: copy.home.featureCards.offlineAi.title,
  modal: copy.home.offlineAiModal,
};
---

<Hero
  client:idle
  title={copy.home.heroTitle}
  titleAccent={copy.home.heroAccent}
  subtitle={copy.home.heroSubtitle}
  subtitleHighlights={copy.home.heroHighlights}
  buyLabel={copy.home.buyPro}
  downloadLabel={copy.header.download}
  downloadEdgeLabel={FREE_DOWNLOAD_BADGE_LABEL}
  downloadMenu={copy.downloadMenu}
  trustSignals={copy.home.trustSignals}
  reviewsHref='#reviews'
  reviewsLabel={copy.header.reviews}
  secondaryHref={secondaryHref}
  videoShowcaseByOS={heroVideoShowcaseByOS}
  macVersion={macVersion}
  windowsVersion={windowsVersion}
  offlineBadge={offlineBadge}
/>
<Features
  title={copy.home.featuresTitle}
  description={copy.home.featuresDescription}
  copy={copy.home.featureCards}
  compactTopSpacing
/>
<Tour client:visible copy={copy.home.showcase} />
{locale === 'en' && <EvidenceSignals />}
<Testimonials locale={locale} />
<SupportedFormats
  title={copy.home.supportedFormats}
  imagesLabel={copy.home.images}
  designLabel={copy.home.designLabel}
  documentsLabel={copy.home.documents}
  videosLabel={copy.home.videosLabel}
  audioLabel={copy.home.audioLabel}
/>
<CloudFolders
  title={copy.home.cloudFoldersTitle}
  description={copy.home.cloudFoldersDescription}
/>
<HomeWorkflows copy={copy.home.workflows} locale={locale} />
{locale === 'en' && <HomeBlogHighlights />}
<DownloadCTA
  title={copy.home.downloadTitle}
  subtitle={copy.home.downloadSubtitle}
  hintPrefix={copy.home.downloadHintPrefix}
  downloadLabel={copy.header.download}
  downloadMenu={copy.downloadMenu}
/>
<CrossPlatformBanner locale={locale} />
<Pricing copy={copy.pricing} />
<FAQ
  client:visible
  title={copy.home.faqTitle}
  description={copy.home.faqDescription}
  items={copy.home.faqItems}
/>
