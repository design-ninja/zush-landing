---
import {
  Blocks,
  Files,
  Gift,
  Languages,
} from 'lucide-react';
import {
  APP_CONFIG,
  APP_STORE_URL,
  CRUNCHBASE_URL,
  LINKEDIN_COMPANY_URL,
  PRODUCT_HUNT_URL,
  SUPPORTED_FORMAT_COUNT,
  WINDOWS_STORE_URL,
} from '@/constants';
import Heading from '@/components/Heading';
import PillLink from '@/components/PillLink';
import Text from '@/components/Text';
import sectionHeaderStyles from '@/components/SectionHeader/SectionHeader.module.scss';
import {
  DEFAULT_LOCALE,
  getLocalesForRoute,
  getLocalizedPath,
  isLocalizedRoute,
  type Locale,
} from '@/i18n/config';
import { getEvidenceSignalsCopy } from '@/i18n/evidenceSignals';
import styles from './EvidenceSignals.module.scss';

interface Props {
  locale?: Locale;
}

const { locale = DEFAULT_LOCALE } = Astro.props as Props;
const copy = getEvidenceSignalsCopy(locale);
const titleParts = copy.title.split('Zush');
const description = copy.description.replace('{count}', String(SUPPORTED_FORMAT_COUNT));

const localizedHref = (route: string): string =>
  isLocalizedRoute(route) && getLocalesForRoute(route).includes(locale)
    ? getLocalizedPath(route, locale)
    : route;

const facts = [
  {
    icon: Gift,
    title: copy.freeTitle,
    description: copy.freeDescription.replace('{limit}', String(APP_CONFIG.free_tier_limit)),
    color: 'green',
  },
  {
    icon: Blocks,
    title: copy.blocksTitle,
    description: copy.blocksDescription,
    color: 'blue',
  },
  {
    icon: Languages,
    title: copy.languagesTitle,
    description: copy.languagesDescription,
    color: 'purple',
  },
  {
    icon: Files,
    title: copy.formatsTitle.replace('{count}', String(SUPPORTED_FORMAT_COUNT)),
    description: copy.formatsDescription,
    color: 'orange',
  },
];

const sourceLinks = [
  { href: localizedHref('/'), label: copy.links.home },
  { href: localizedHref('/mac'), label: copy.links.mac },
  { href: localizedHref('/windows'), label: copy.links.windows },
  { href: localizedHref('/batch-rename-files'), label: copy.links.batchRename },
  { href: localizedHref('/ai-file-organizer'), label: copy.links.organizer },
  { href: localizedHref('/methodology'), label: copy.links.methodology },
  { href: localizedHref('/about'), label: copy.links.about },
  { href: '/authors/kirill-isachenko', label: copy.links.author },
  { href: '/pricing.md', label: copy.links.pricing },
  { href: localizedHref('/changelog'), label: copy.links.changelog },
  { href: '/llms.txt', label: 'llms.txt' },
  { href: localizedHref('/privacy-policy'), label: copy.links.privacy },
  { href: APP_STORE_URL, label: 'Mac App Store', external: true },
  { href: WINDOWS_STORE_URL, label: 'Microsoft Store', external: true },
  { href: PRODUCT_HUNT_URL, label: 'Product Hunt', external: true },
  { href: LINKEDIN_COMPANY_URL, label: 'LinkedIn', external: true },
  { href: CRUNCHBASE_URL, label: 'Crunchbase', external: true },
];
---

<section class={styles.EvidenceSignals} aria-labelledby="about-zush-title" data-scroll-reveal-skip>
  <div class={styles.EvidenceSignals__Container}>
    <div class={sectionHeaderStyles.SectionHeader}>
      <Heading id="about-zush-title" as="h2" align="center" className={sectionHeaderStyles.SectionHeader__Title}>
        {titleParts[0]}{titleParts.length > 1 ? <span class="brand-accent-text">Zush</span> : null}{titleParts.slice(1).join('Zush')}
      </Heading>
      <Text as="p" size="lg" color="subtle" align="center" className={sectionHeaderStyles.SectionHeader__Description}>
        {description}
      </Text>
    </div>

    <dl class={styles.EvidenceSignals__Facts}>
      {facts.map((fact) => {
        const Icon = fact.icon;

        return (
          <div class={`${styles.EvidenceSignals__Fact} ${styles[`EvidenceSignals__Fact_${fact.color}`]}`}>
            <dt class={styles.EvidenceSignals__FactTitle}>
              <Icon size={20} aria-hidden="true" />
              <span>{fact.title}</span>
            </dt>
            <dd class={styles.EvidenceSignals__FactDescription}>{fact.description}</dd>
          </div>
        );
      })}
    </dl>

    <div class={styles.EvidenceSignals__Sources}>
      <Heading as="h3" size="h4" align="center" className={styles.EvidenceSignals__SourcesTitle}>
        {copy.sourcesTitle}
      </Heading>
      <div class={styles.EvidenceSignals__SourceLinks}>
        {sourceLinks.map((link) => (
          <PillLink
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
            size="sm"
          >
            {link.label}
          </PillLink>
        ))}
      </div>
    </div>
  </div>
</section>
