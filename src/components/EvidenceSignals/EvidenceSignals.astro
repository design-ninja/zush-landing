---
import {
  Blocks,
  Files,
  Gift,
  Languages,
} from 'lucide-react';
import { APP_CONFIG, APP_STORE_URL, SUPPORTED_FORMAT_COUNT, WINDOWS_STORE_URL } from '@/constants';
import Heading from '@/components/Heading';
import PillLink from '@/components/PillLink';
import Text from '@/components/Text';
import sectionHeaderStyles from '@/components/SectionHeader/SectionHeader.module.scss';
import formatStyles from '@/components/SupportedFormats/SupportedFormats.module.scss';
import useCaseStyles from '@/components/UseCases/UseCases.module.scss';

const facts = [
  {
    icon: Gift,
    title: 'Free to try',
    description: `${APP_CONFIG.free_tier_limit} AI renames before purchase, with no signup or credit card required.`,
    color: 'green',
  },
  {
    icon: Blocks,
    title: '145+ Naming Blocks',
    description: 'Build filenames from dates, metadata, audio details, finance fields, clients, travel, legal, and AI-detected context.',
    color: 'blue',
  },
  {
    icon: Languages,
    title: '60+ filename languages',
    description: 'Generate searchable names in the language and date format that fits each folder or team.',
    color: 'purple',
  },
  {
    icon: Files,
    title: `${SUPPORTED_FORMAT_COUNT} supported formats`,
    description: 'Images, RAW photos, design files, PDFs, Office and iWork files, subtitles, audio, and videos can live in one rename workflow.',
    color: 'orange',
  },
];

const sourceLinks = [
  { href: '/', label: 'AI file renamer' },
  { href: '/mac', label: 'Mac AI file renamer' },
  { href: '/windows', label: 'Windows AI file renamer' },
  { href: '/batch-rename-files', label: 'Batch rename files' },
  { href: '/ai-file-organizer', label: 'AI file organizer' },
  { href: '/methodology', label: 'Methodology' },
  { href: '/about', label: 'About Zush' },
  { href: '/authors/kirill-isachenko', label: 'Author' },
  { href: '/pricing.md', label: 'Pricing facts' },
  { href: '/changelog', label: 'Changelog' },
  { href: '/llms.txt', label: 'llms.txt' },
  { href: '/privacy-policy', label: 'Privacy' },
  { href: APP_STORE_URL, label: 'Mac App Store', external: true },
  { href: WINDOWS_STORE_URL, label: 'Microsoft Store', external: true },
  { href: 'https://www.producthunt.com/products/zush', label: 'Product Hunt', external: true },
];
---

<section class={useCaseStyles.UseCases}>
  <div class={useCaseStyles.UseCases__Container}>
    <div class={sectionHeaderStyles.SectionHeader}>
      <Heading as="h2" align="center" className={sectionHeaderStyles.SectionHeader__Title}>
        What is <span class="brand-accent-text">Zush</span>
      </Heading>
      <Text as="p" size="lg" color="subtle" align="center" className={sectionHeaderStyles.SectionHeader__Description}>
        AI file renaming and organization by content for Mac and Windows, with batch rename, bulk review, templates, monitoring, BYOK, and one-click revert.
      </Text>
    </div>

    <div class={`${useCaseStyles.UseCases__Grid} evidenceFactsGrid`}>
      {facts.map((fact) => {
        const Icon = fact.icon;

        return (
          <article
            class={`${useCaseStyles.UseCaseCard} ${useCaseStyles[`UseCaseCard_${fact.color}`]} evidenceFactCard evidenceFactCard_${fact.color}`}
          >
            <div class={`${useCaseStyles.UseCaseCard__IconWrapper} evidenceFactIcon`}>
              <Icon size={24} />
            </div>
            <Heading as="h3" className={useCaseStyles.UseCaseCard__Title}>
              {fact.title}
            </Heading>
            <Text className={useCaseStyles.UseCaseCard__Description}>
              {fact.description}
            </Text>
          </article>
        );
      })}
    </div>

    <div class={`${formatStyles.SupportedFormats} ${formatStyles.SupportedFormats__Group}`}>
      <Heading as="h3" size="h4" align="center" className={formatStyles.SupportedFormats__GroupTitle}>
        Sources
      </Heading>
      <div class={formatStyles.SupportedFormats__Tags}>
        {sourceLinks.map((link) => (
          <PillLink
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
            size="sm"
          >
            {link.label}
          </PillLink>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .evidenceFactsGrid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .evidenceFactsGrid .evidenceFactCard {
    --fact-accent: var(--tone-green-fg);
    --fact-card-bg: color-mix(in srgb, var(--fact-accent) 8%, var(--background));
    --fact-card-border: color-mix(in srgb, var(--fact-accent) 24%, transparent);
    --fact-icon-bg: color-mix(in srgb, var(--fact-accent) 15%, transparent);

    background: var(--fact-card-bg);
    border-color: var(--fact-card-border);
  }

  .evidenceFactsGrid .evidenceFactIcon {
    background: var(--fact-icon-bg);
    color: var(--fact-accent);
  }

  .evidenceFactsGrid .evidenceFactCard_green {
    --fact-accent: var(--tone-green-fg);
  }

  .evidenceFactsGrid .evidenceFactCard_blue {
    --fact-accent: var(--tone-blue-fg);
  }

  .evidenceFactsGrid .evidenceFactCard_purple {
    --fact-accent: var(--tone-purple-fg);
  }

  .evidenceFactsGrid .evidenceFactCard_orange {
    --fact-accent: var(--tone-orange-fg);
  }

  :global(html[data-theme='dark']) .evidenceFactsGrid .evidenceFactCard {
    --fact-card-bg: color-mix(in srgb, var(--fact-accent) 11%, var(--card));
    --fact-card-border: color-mix(in srgb, var(--fact-accent) 26%, transparent);
    --fact-icon-bg: color-mix(in srgb, var(--fact-accent) 24%, transparent);
  }

  @media (max-width: 1024px) {
    .evidenceFactsGrid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .evidenceFactsGrid {
      grid-template-columns: 1fr;
    }
  }
</style>
