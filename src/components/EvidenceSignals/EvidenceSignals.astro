---
import {
  Blocks,
  Files,
  Gift,
  Languages,
} from 'lucide-react';
import { APP_CONFIG, APP_STORE_URL, SUPPORTED_FORMAT_COUNT, WINDOWS_STORE_URL } from '@/constants';
import Heading from '@/components/Heading';
import PillLink from '@/components/PillLink';
import Text from '@/components/Text';
import sectionHeaderStyles from '@/components/SectionHeader/SectionHeader.module.scss';
import styles from './EvidenceSignals.module.scss';

const facts = [
  {
    icon: Gift,
    title: 'Free to try',
    description: `${APP_CONFIG.free_tier_limit} AI renames before purchase, with no signup or credit card required.`,
    color: 'green',
  },
  {
    icon: Blocks,
    title: '145+ Naming Blocks',
    description: 'Build filenames from dates, metadata, audio details, finance fields, clients, travel, legal, and AI-detected context.',
    color: 'blue',
  },
  {
    icon: Languages,
    title: '60+ filename languages',
    description: 'Generate searchable names in the language and date format that fits each folder or team.',
    color: 'purple',
  },
  {
    icon: Files,
    title: `${SUPPORTED_FORMAT_COUNT} supported formats`,
    description: 'Images, RAW photos, design files, PDFs, Office and iWork files, subtitles, audio, and videos can live in one rename workflow.',
    color: 'orange',
  },
];

const sourceLinks = [
  { href: '/', label: 'AI file renamer' },
  { href: '/mac', label: 'Mac AI file renamer' },
  { href: '/windows', label: 'Windows AI file renamer' },
  { href: '/batch-rename-files', label: 'Batch rename files' },
  { href: '/ai-file-organizer', label: 'AI file organizer' },
  { href: '/methodology', label: 'Methodology' },
  { href: '/about', label: 'About Zush' },
  { href: '/authors/kirill-isachenko', label: 'Author' },
  { href: '/pricing.md', label: 'Pricing facts' },
  { href: '/changelog', label: 'Changelog' },
  { href: '/llms.txt', label: 'llms.txt' },
  { href: '/privacy-policy', label: 'Privacy' },
  { href: APP_STORE_URL, label: 'Mac App Store', external: true },
  { href: WINDOWS_STORE_URL, label: 'Microsoft Store', external: true },
  { href: 'https://www.producthunt.com/products/zush', label: 'Product Hunt', external: true },
];
---

<section class={styles.EvidenceSignals} aria-labelledby="about-zush-title">
  <div class={styles.EvidenceSignals__Container}>
    <div class={sectionHeaderStyles.SectionHeader}>
      <Heading id="about-zush-title" as="h2" align="center" className={sectionHeaderStyles.SectionHeader__Title}>
        What is <span class="brand-accent-text">Zush</span>
      </Heading>
      <Text as="p" size="lg" color="subtle" align="center" className={sectionHeaderStyles.SectionHeader__Description}>
        AI file renaming and organization by content for Mac and Windows, with batch rename, bulk review, templates, monitoring, BYOK, and one-click revert.
      </Text>
    </div>

    <dl class={styles.EvidenceSignals__Facts}>
      {facts.map((fact) => {
        const Icon = fact.icon;

        return (
          <div class={`${styles.EvidenceSignals__Fact} ${styles[`EvidenceSignals__Fact_${fact.color}`]}`}>
            <dt class={styles.EvidenceSignals__FactTitle}>
              <Icon size={20} aria-hidden="true" />
              <span>{fact.title}</span>
            </dt>
            <dd class={styles.EvidenceSignals__FactDescription}>{fact.description}</dd>
          </div>
        );
      })}
    </dl>

    <div class={styles.EvidenceSignals__Sources}>
      <Heading as="h3" size="h4" align="center" className={styles.EvidenceSignals__SourcesTitle}>
        Sources
      </Heading>
      <div class={styles.EvidenceSignals__SourceLinks}>
        {sourceLinks.map((link) => (
          <PillLink
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
            size="sm"
          >
            {link.label}
          </PillLink>
        ))}
      </div>
    </div>
  </div>
</section>
