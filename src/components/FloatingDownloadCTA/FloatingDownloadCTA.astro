---
import DownloadButton from '@/components/DownloadButton/DownloadButton';
import type { DownloadOS } from '@/utils/download';
import { FREE_DOWNLOAD_BADGE_LABEL } from '@/constants';
import styles from './FloatingDownloadCTA.module.scss';

interface Props {
  forceOS?: DownloadOS;
  label: string;
}

const { forceOS, label } = Astro.props as Props;
---

<div
  class={styles.FloatingDownloadCTA}
  data-floating-download
  data-active='false'
  data-visible='false'
  aria-hidden='true'
>
  <DownloadButton
    client:idle
    source='floating-cta'
    variant='black'
    size='lg'
    label={label}
    labelAccent='Zush'
    edgeLabel={FREE_DOWNLOAD_BADGE_LABEL}
    surface='greenGlow'
    forceOS={forceOS}
    showDropdown={false}
  />
</div>
