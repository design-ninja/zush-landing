---
import { ClientRouter } from 'astro:transitions';
import type { SeoMeta } from '@/seo/config';
import { DEFAULT_OG_IMAGE, getCanonicalUrl } from '@/seo/config';
import '@/styles/main.scss';
import Header from '@/components/Header/Header.astro';
import Footer from '@/components/Footer/Footer.astro';
import type { DownloadOS } from '@/utils/download';
import Analytics from '@vercel/analytics/astro';

const crossfadeEasing = 'cubic-bezier(0.4, 0, 0.2, 1)';
const crossfadeDuration = '0.32s';

const mainSlide = {
  forwards: {
    old: {
      name: 'zush-vt-old-forward',
      duration: crossfadeDuration,
      easing: crossfadeEasing,
      fillMode: 'both',
    },
    new: {
      name: 'zush-vt-new-forward',
      duration: crossfadeDuration,
      easing: crossfadeEasing,
      fillMode: 'both',
    },
  },
  backwards: {
    old: {
      name: 'zush-vt-old-back',
      duration: crossfadeDuration,
      easing: crossfadeEasing,
      fillMode: 'both',
    },
    new: {
      name: 'zush-vt-new-back',
      duration: crossfadeDuration,
      easing: crossfadeEasing,
      fillMode: 'both',
    },
  },
};

interface Props {
  seo: SeoMeta;
  jsonLd?: object | object[];
  includeChrome?: boolean;
  forceOS?: DownloadOS;
  chromeBasePath?: string;
  disableTopOffset?: boolean;
}

const {
  seo,
  jsonLd,
  includeChrome = true,
  forceOS,
  chromeBasePath = '/',
  disableTopOffset = false,
} = Astro.props;

const canonicalUrl = getCanonicalUrl(seo.canonicalPath);
const ogImage = seo.ogImage || DEFAULT_OG_IMAGE;
const ldItems = (Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [])
  .filter(Boolean);
const isHomePage = seo.canonicalPath === '/';
const needsTopOffset = includeChrome && !isHomePage && !disableTopOffset;
---

<!doctype html>
<html lang="en" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <ClientRouter />

    <script is:inline>
      (() => {
        const THEME_STORAGE_KEY = 'zush-theme';
        const root = () => document.documentElement;
        const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');

        const getStoredTheme = () => {
          try {
            const storedTheme = window.localStorage.getItem(THEME_STORAGE_KEY);
            if (storedTheme === 'dark' || storedTheme === 'light') {
              return storedTheme;
            }
          } catch {}

          return null;
        };

        const getTheme = () => getStoredTheme() ?? (mediaQuery.matches ? 'dark' : 'light');

        const applyTheme = (target = root(), theme = getTheme()) => {
          target.setAttribute('data-theme', theme);
        };
        const enableScrollReveal = (target = root()) => {
          target.setAttribute('data-scroll-reveal', 'enabled');
        };

        if (!window.__zushThemeManagerBound) {
          window.__zushThemeManagerBound = true;

          const toggleTheme = () => {
            const nextTheme = getTheme() === 'light' ? 'dark' : 'light';

            try {
              window.localStorage.setItem(THEME_STORAGE_KEY, nextTheme);
            } catch {}

            applyTheme(root(), nextTheme);
          };

          applyTheme();
          enableScrollReveal();
          mediaQuery.addEventListener('change', (event) => {
            if (getStoredTheme()) return;
            applyTheme(root(), event.matches ? 'dark' : 'light');
          });

          document.addEventListener('click', (event) => {
            const target = event.target instanceof Element ? event.target.closest('[data-theme-toggle]') : null;
            if (!target) return;
            toggleTheme();
          });

          document.addEventListener('astro:before-swap', (event) => {
            applyTheme(event.newDocument.documentElement);
            enableScrollReveal(event.newDocument.documentElement);
          });
          document.addEventListener('astro:after-swap', () => {
            applyTheme();
            enableScrollReveal();
          });
          return;
        }

        applyTheme(root(), root().getAttribute('data-theme') || getTheme());
        enableScrollReveal();
      })();
    </script>

    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta name="robots" content={seo.robots} />
    <link rel="canonical" href={canonicalUrl} />

    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />

    <meta property="og:type" content={seo.ogType ?? 'website'} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Zush" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Zush — AI File Renamer for Mac and Windows" />
    {seo.publishedTime && <meta property="article:published_time" content={seo.publishedTime} />}
    {seo.modifiedTime && <meta property="article:modified_time" content={seo.modifiedTime} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Zush — AI File Renamer for Mac and Windows" />
    <meta name="twitter:site" content="@zush_app" />
    <meta name="twitter:creator" content="@zush_app" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,100..900&family=Outfit:wght@100..900&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,100..900&family=Outfit:wght@100..900&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,100..900&family=Outfit:wght@100..900&display=swap"
        rel="stylesheet"
      />
    </noscript>

    {
      ldItems.map((item) => (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(item)}
        />
      ))
    }
  </head>
  <body>
    <div class="site-shell">
      <a class="skip-link" href="#main-content">Skip to content</a>
      {includeChrome && <Header forceOS={forceOS} basePath={chromeBasePath} />}
      <main
        id="main-content"
        class:list={['site-main', { 'site-main_offset': needsTopOffset }]}
        transition:animate={mainSlide}
      >
        <slot />
      </main>
      {includeChrome && <Footer />}
      <script>
        import { bindCheckoutAutoOpen } from '@/utils/checkoutAutoOpen';
        import { bindPricingCheckout } from '@/utils/pricingCheckout';
        import { bindScrollReveal } from '@/utils/scrollReveal';
        import { bindStoreLinks } from '@/utils/storeLinks';

        bindCheckoutAutoOpen();
        bindPricingCheckout();
        bindScrollReveal();
        bindStoreLinks();
        document.addEventListener('astro:after-swap', () => {
          bindCheckoutAutoOpen();
          bindPricingCheckout();
          bindScrollReveal();
          bindStoreLinks();
        });
      </script>
    </div>
    <Analytics />
  </body>
</html>

<style>
  .site-shell {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
  }

  .site-main {
    flex: 1;
  }

  .site-main_offset {
    padding-top: calc(var(--navbar-height, 4.375rem) + 0.9rem);
  }

  @media (max-width: 768px) {
    .site-main_offset {
      padding-top: calc(var(--navbar-height, 4.375rem) + 0.55rem);
    }
  }

  .skip-link {
    position: absolute;
    top: 0;
    left: 0;
    transform: translateY(-120%);
    background: var(--primary, #111);
    color: #fff;
    padding: 0.6rem 0.9rem;
    z-index: 1000;
    border-radius: 0 0 0.5rem 0;
  }

  .skip-link:focus {
    transform: translateY(0);
  }
</style>

<style is:global>
  ::view-transition {
    background-color: var(--background);
  }

  ::view-transition-old(*),
  ::view-transition-new(*) {
    mix-blend-mode: normal;
  }

  @keyframes zush-vt-old-forward {
    from {
      opacity: 1;
    }

    to {
      opacity: 0;
    }
  }

  @keyframes zush-vt-new-forward {
    from {
      opacity: 0;
      transform: scale(0.98);
    }

    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes zush-vt-old-back {
    from {
      opacity: 1;
    }

    to {
      opacity: 0;
    }
  }

  @keyframes zush-vt-new-back {
    from {
      opacity: 0;
      transform: scale(1.02);
    }

    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  html[data-scroll-reveal='enabled'] [data-scroll-reveal] {
    opacity: 0;
    transform: translate3d(0, 1.5rem, 0);
    transition:
      opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }

  html[data-scroll-reveal='enabled']
    [data-scroll-reveal]:not([data-scroll-reveal-state='visible']) {
    will-change: opacity, transform;
  }

  html[data-scroll-reveal='enabled']
    [data-scroll-reveal][data-scroll-reveal-state='visible'] {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  @media (prefers-reduced-motion: reduce) {
    html[data-scroll-reveal='enabled'] [data-scroll-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }

    ::view-transition-group(*),
    ::view-transition-old(*),
    ::view-transition-new(*) {
      animation-duration: 0s !important;
    }
  }
</style>
